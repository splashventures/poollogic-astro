---
import { company } from '@/data/company';
import { formatPhoneLink } from '@/lib/utils';

const quickLinks = [
  { name: 'Get a Quote', href: company.quoteUrl },
  { name: 'Commercial Pool Service', href: '/commercial-pool-service/' },
  { name: 'Resources', href: '/resources/' },
  { name: 'Reviews', href: '/reviews/' },
  { name: 'Jobs & Careers', href: '/jobs-careers/' },
  { name: 'Sell Your Pool Service Company', href: '/sell-pool-service-company/' },
];

const maintenanceLinks = [
  { name: 'Weekly Pool Cleaning', href: '/weekly-pool-cleaning-service/' },
  { name: 'Pool Filter Cleaning', href: '/pool-filter-cleaning-service/' },
  { name: 'Pool Drain & Restart', href: '/pool-draining-restart-service/' },
  { name: 'Pool Algae Removal', href: '/pool-algae-removal-service/' },
  { name: 'Hot Tub Cleaning', href: '/hot-tub-cleaning-service/' },
  { name: 'Pool Acid Washing', href: '/pool-acid-washing-service/' },
];

const repairLinks = [
  { name: 'Pool Heater Repair', href: '/pool-heater-repair-service/' },
  { name: 'Pool Pump Repair', href: '/pool-pump-repair-service/' },
  { name: 'Pool Filter Repair', href: '/pool-filter-repair-service/' },
  { name: 'Pool Light Repair', href: '/pool-light-repair-service/' },
  { name: 'Pool Light Replacement', href: '/pool-light-replacement-service/' },
  { name: 'Pool Automation Repair', href: '/pool-automation-repair-service/' },
  { name: 'Salt Water Pool Repair', href: '/salt-water-pool-repair-service/' },
];

const installLinks = [
  { name: 'Pool Heater Install', href: '/pool-heater-installation-service/' },
  { name: 'Pool Pump Install', href: '/pool-pump-installation-service/' },
  { name: 'Pool Filter Install', href: '/pool-filter-installation-service/' },
  { name: 'Pool Automation Install', href: '/pool-automation-installation-service/' },
];

const legalLinks = [
  { name: 'Privacy Policy', href: '/privacy-policy/' },
  { name: 'Terms of Use', href: '/terms-of-use/' },
  { name: 'Sitemap', href: '/html-sitemap/' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8 lg:gap-12">
      <!-- Company info -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4">
          <img src="/images/logos/cabana-logo-blue.svg" alt="Cabana Pools" class="h-8 w-auto brightness-0 invert" />
        </a>
        <p class="text-gray-400 mb-4 text-sm">
          Professional pool cleaning, maintenance, repairs, and installations across California.
        </p>
        <div class="space-y-2 text-sm">
          <p class="font-semibold text-white">{company.name}</p>
          <p>{company.address.full}</p>
          <p>
            <a href={formatPhoneLink(company.phone)} class="hover:text-white transition-colors">
              {company.phone}
            </a>
          </p>
          <p>
            <a href={`mailto:${company.email}`} class="hover:text-white transition-colors">
              {company.email}
            </a>
          </p>
          <p class="text-gray-500">Contractors License #: {company.contractorsLicense}</p>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-white transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Maintenance Services -->
      <div>
        <h3 class="text-white font-semibold mb-4">Maintenance Services</h3>
        <ul class="space-y-2 text-sm">
          {maintenanceLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-white transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Repair Services -->
      <div>
        <h3 class="text-white font-semibold mb-4">Repair Services</h3>
        <ul class="space-y-2 text-sm">
          {repairLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-white transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Equipment Installs -->
      <div>
        <h3 class="text-white font-semibold mb-4">Equipment Installs</h3>
        <ul class="space-y-2 text-sm">
          {installLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-white transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-sm text-gray-400">
          &copy; {currentYear} Cabana. All rights reserved.
        </p>
        <div class="flex gap-6 text-sm">
          {legalLinks.map((link) => (
            <a href={link.href} class="text-gray-400 hover:text-white transition-colors">
              {link.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>
