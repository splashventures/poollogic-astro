---
interface Props {
  name: string;
  location: string;
  text: string;
  rating: number;
  yearsCustomer?: number;
}

const { name, location, text, rating, yearsCustomer } = Astro.props;

const stars = Array.from({ length: rating }, (_, i) => i);
---

<div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 h-full flex flex-col">
  <!-- Stars -->
  <div class="flex gap-1 mb-4">
    {stars.map(() => (
      <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  <!-- Quote -->
  <blockquote class="text-gray-700 text-lg leading-relaxed flex-grow">
    &ldquo;{text}&rdquo;
  </blockquote>

  <!-- Author -->
  <div class="mt-6 pt-6 border-t border-gray-100 flex items-center gap-4">
    <div class="w-12 h-12 bg-gradient-to-br from-[#88d2c7] to-[#00568c] rounded-full flex items-center justify-center text-white font-semibold text-lg">
      {name.charAt(0)}
    </div>
    <div>
      <div class="font-semibold text-gray-900">{name}</div>
      <div class="text-gray-500 text-sm">
        {location}
        {yearsCustomer && (
          <span> · Customer for {yearsCustomer} years</span>
        )}
      </div>
    </div>
  </div>
</div>
