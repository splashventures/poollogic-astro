---
import { company } from '@/data/company';

const stats = [
  { value: '5.0 ★', label: 'Google Rating' },
  { value: `${company.poolsServed.toLocaleString()}+`, label: 'Pools Served' },
  { value: '22', label: 'Cities Served' },
  { value: '100%', label: 'Satisfaction Guarantee' },
];
---

<div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
  {stats.map((stat) => (
    <div class="text-center">
      <div class="text-4xl lg:text-5xl font-bold text-[#00568c] mb-2">{stat.value}</div>
      <div class="text-gray-600 text-sm font-medium">{stat.label}</div>
    </div>
  ))}
</div>
