---
import { company } from '@/data/company';

const stats = [
  { value: `${company.rating.value}`, label: 'Google Rating', isStar: true, href: 'https://g.co/kgs/NKwnBPz' },
  { value: `${company.poolsServed.toLocaleString()}+`, label: 'Pools Served' },
  { value: '22', label: 'Cities Served' },
  { value: '100%', label: 'Satisfaction Guarantee' },
];
---

<div class="grid grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
  {stats.map((stat) => (
    <div class="text-center">
      {stat.href ? (
        <a href={stat.href} target="_blank" rel="noopener noreferrer" class="group inline-block">
          <div class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#00568c] mb-2 group-hover:text-[#004a7a] transition-colors flex items-center justify-center gap-1">
            {stat.value}
            {stat.isStar && (
              <svg class="h-7 w-7 sm:h-8 sm:w-8 lg:h-10 lg:w-10 text-yellow-400 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            )}
          </div>
          <div class="text-gray-600 text-xs sm:text-sm font-medium group-hover:text-[#00568c] transition-colors">{stat.label}</div>
        </a>
      ) : (
        <>
          <div class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#00568c] mb-2">{stat.value}</div>
          <div class="text-gray-600 text-xs sm:text-sm font-medium">{stat.label}</div>
        </>
      )}
    </div>
  ))}
</div>
