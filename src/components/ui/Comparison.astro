---
const comparisonData = [
  { feature: 'Consistent weekly scheduling', us: true, others: false },
  { feature: 'Same technician every visit', us: true, others: false },
  { feature: 'All chemicals included', us: true, others: false },
  { feature: 'Digital service reports with photos', us: true, others: false },
  { feature: 'CPO-certified technicians', us: true, others: false },
  { feature: '100% satisfaction guarantee', us: true, others: false },
  { feature: 'Transparent, upfront pricing', us: true, others: false },
];
---

<section class="py-16 lg:py-28">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-8 sm:mb-12">
      <p class="text-[#00568c] font-semibold mb-3">WHY WE'RE DIFFERENT</p>
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Not all pool services are created equal
      </h2>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto">
        We built PoolLogic to fix everything we hated about other pool services
      </p>
    </div>

    <!-- Comparison Table -->
    <div class="overflow-x-auto -mx-4 px-4 sm:mx-0 sm:px-0">
      <!-- Swipe hint: visible only on small screens where the table may overflow -->
      <p class="flex items-center justify-center gap-1.5 text-xs text-gray-400 mb-2 sm:hidden">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        Swipe to see full table
        <svg class="h-4 w-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </p>
      <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden min-w-[420px] sm:min-w-0">
        <!-- Header -->
        <div class="grid grid-cols-[1fr_80px_80px] sm:grid-cols-3 bg-gray-50 border-b border-gray-200">
          <div class="p-3 sm:p-4 lg:p-6"></div>
          <div class="p-3 sm:p-4 lg:p-6 text-center border-l border-gray-200">
            <div class="font-bold text-gray-900 text-base">PoolLogic</div>
            <div class="text-sm text-[#00568c] font-medium">What you get</div>
          </div>
          <div class="p-3 sm:p-4 lg:p-6 text-center border-l border-gray-200">
            <div class="font-bold text-gray-500 text-base">Others</div>
            <div class="text-sm text-gray-500">What they offer</div>
          </div>
        </div>

        <!-- Rows -->
        {comparisonData.map((row, index) => (
          <div
            class:list={[
              'grid grid-cols-[1fr_80px_80px] sm:grid-cols-3',
              index !== comparisonData.length - 1 ? 'border-b border-gray-100' : '',
            ]}
          >
            <div class="p-3 sm:p-4 lg:p-5 text-gray-700 font-medium text-sm lg:text-base">
              {row.feature}
            </div>
            <div class="p-3 sm:p-4 lg:p-5 flex justify-center items-center border-l border-gray-100 bg-green-50/50">
              <div class="w-7 h-7 sm:w-8 sm:h-8 bg-green-100 rounded-full flex items-center justify-center">
                <svg class="h-4 w-4 sm:h-5 sm:w-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
            </div>
            <div class="p-3 sm:p-4 lg:p-5 flex justify-center items-center border-l border-gray-100">
              <div class="w-7 h-7 sm:w-8 sm:h-8 bg-gray-100 rounded-full flex items-center justify-center">
                <svg class="h-4 w-4 sm:h-5 sm:w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
