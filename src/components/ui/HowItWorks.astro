---
import { Image } from 'astro:assets';
import { company } from '@/data/company';
import Button from '@/components/ui/Button.astro';
import phoneImg from '@/assets/images/pool/phone.jpg';
import handleEverythingImg from '@/assets/images/pool/step-handle-everything.webp';
import enjoyPoolImg from '@/assets/images/pool/step-enjoy-pool.webp';

const steps = [
  {
    number: '1',
    title: 'Get your free quote',
    description:
      "No two pools are the same, and your quote shouldn't be either. Tell us about your pool and we'll have a personalized estimate ready in minutes.",
    image: phoneImg,
    imageAlt: 'Smartphone with quote form, sunglasses and drink on sunny pool deck',
    highlight: '2-minute form',
  },
  {
    number: '2',
    title: 'We handle everything',
    description:
      'Your dedicated technician arrives weekly at the same time. We test, balance, clean, and inspect, then send you a detailed report.',
    image: handleEverythingImg,
    imageAlt: 'Pool technician with pole servicing residential pool in San Diego',
    highlight: 'Same tech every week',
  },
  {
    number: '3',
    title: 'Enjoy your pool',
    description:
      'Spend your time swimming, not maintaining. Your pool stays crystal clear, safe, and ready whenever you want.',
    image: enjoyPoolImg,
    imageAlt: 'Beautiful crystal clear pool with floats and tropical landscaping',
    highlight: 'Crystal clear, always',
  },
];
---

<section class="py-16 lg:py-28 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-10 sm:mb-16 lg:mb-20">
      <p class="text-[#00568c] font-semibold tracking-wide uppercase text-sm mb-3">
        How It Works
      </p>
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Professional pool care in 3 simple steps
      </h2>
      <p class="text-base sm:text-lg text-gray-600">
        CPO-certified technicians, no hassle. Just crystal-clear water and
        your weekends back.
      </p>
    </div>

    <!-- Steps - alternating rows -->
    <div class="space-y-16 lg:space-y-24">
      {steps.map((step, index) => {
        const isReversed = index % 2 !== 0;
        return (
          <div
            class:list={[
              'flex flex-col items-center gap-8 lg:gap-16',
              isReversed ? 'lg:flex-row-reverse' : 'lg:flex-row',
            ]}
          >
            <!-- Image side -->
            <div class="w-full lg:w-1/2">
              <div class="relative rounded-2xl overflow-hidden shadow-xl aspect-[3/2] sm:aspect-[4/3]">
                <Image
                  src={step.image}
                  alt={step.imageAlt}
                  width={800}
                  height={600}
                  class="object-cover w-full h-full absolute inset-0"
                  loading="lazy"
                />
                <!-- Number badge -->
                <div class="absolute top-5 left-5 flex items-center justify-center w-12 h-12 rounded-full bg-[#00568c] text-white text-xl font-bold shadow-lg">
                  {step.number}
                </div>
              </div>
            </div>

            <!-- Content side -->
            <div class="w-full lg:w-1/2">
              <div class="max-w-lg">
                <span class="inline-block text-xs font-semibold tracking-wider uppercase text-[#00568c] bg-[#00568c]/10 px-3 py-1 rounded-full mb-4">
                  Step {step.number}
                </span>
                <h3 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-4">
                  {step.title}
                </h3>
                <p class="text-gray-600 text-lg leading-relaxed mb-5">
                  {step.description}
                </p>
                <div class="flex items-center gap-2 text-[#00568c] font-semibold">
                  <svg
                    class="h-5 w-5"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  {step.highlight}
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- CTA -->
    <div class="text-center mt-16 lg:mt-20">
      <Button href={company.quoteUrl} external size="lg">
        Get Your Free Quote
      </Button>
      <p class="text-sm text-gray-500 mt-3">
        No commitment. No credit card. Just a quote.
      </p>
    </div>
  </div>
</section>
