---
interface Props {
  placeIds: string[];
  maxReviews?: number;
  googleProfileUrl: string;
}

interface Review {
  reviewerName: string;
  reviewerPhotoUrl: string | null;
  rating: number;
  text: string;
  publishedAt: string | null;
  googleReviewUrl: string | null;
  relativeTimeDescription: string;
  placeId: string;
  businessName: string;
}

interface ReviewsResponse {
  reviews: Review[];
  metadata: {
    totalReviews: number;
    averageRating: number;
    lastFetched: string;
  };
}

const { placeIds, maxReviews = 20, googleProfileUrl } = Astro.props;

const FUNCTION_URL = 'https://us-central1-cabana-cac.cloudfunctions.net/google-reviews';

let reviews: Review[] = [];
let totalReviews = 0;
let averageRating = 5.0;
let hasFetched = false;

try {
  const url = `${FUNCTION_URL}?placeIds=${placeIds.join(',')}`;
  const res = await fetch(url);
  if (res.ok) {
    const data: ReviewsResponse = await res.json();
    reviews = data.reviews.slice(0, maxReviews);
    totalReviews = data.metadata.totalReviews;
    averageRating = data.metadata.averageRating;
    hasFetched = true;
  }
} catch {
  // Graceful fallback: render link-only section
}

// External reviews from Trustindex and Thumbtack (scraped 2026-04-13)
const externalReviews: Review[] = [
  { reviewerName: 'Chelsea Royse', reviewerPhotoUrl: null, rating: 5, text: "PoolLogic has been a lifesaver for us. We tried handling our own pool cleaning in San Diego for years, but it always felt like a losing battle. Since switching to their weekly service, our pool has been crystal clear, balanced, and ready to use at any time.", relativeTimeDescription: 'Trustindex', publishedAt: null, googleReviewUrl: null, placeId: '', businessName: 'PoolLogic' },
  { reviewerName: 'Derek W.', reviewerPhotoUrl: null, rating: 5, text: "We've used PoolLogic for about 2 years now and our pool has never looked and performed better. Rony is prompt and professional and does a fantastic job. We love the detail and the education. Highly recommend!", relativeTimeDescription: 'Thumbtack', publishedAt: null, googleReviewUrl: null, placeId: '', businessName: 'PoolLogic' },
  { reviewerName: 'Melissa Rigby', reviewerPhotoUrl: null, rating: 5, text: "We live in La Jolla and the ocean air makes it tough to keep our pool water fresh. PoolLogic came out and performed a full filter cleaning, and the improvement was immediate. This is easily the most thorough filter cleaning service I've had in San Diego County.", relativeTimeDescription: 'Trustindex', publishedAt: null, googleReviewUrl: null, placeId: '', businessName: 'PoolLogic' },
  { reviewerName: 'Sean O.', reviewerPhotoUrl: null, rating: 5, text: "We are new pool owners and after an unpleasant experience with a prior pool cleaning service, I was referred to PoolLogic. Our service technicians Alex and Carlos have demonstrated professionalism, promptness, service knowledge, and are very courteous!", relativeTimeDescription: 'Thumbtack', publishedAt: null, googleReviewUrl: null, placeId: '', businessName: 'PoolLogic' },
  { reviewerName: 'Clint Phillips', reviewerPhotoUrl: null, rating: 5, text: "PoolLogic has been handling our weekly pool service in Mission Hills for a few months now, and the difference is night and day. Before, we were constantly fighting cloudy water. Since hiring them, our pool has been spotless. The technician leaves a service summary after every visit.", relativeTimeDescription: 'Trustindex', publishedAt: null, googleReviewUrl: null, placeId: '', businessName: 'PoolLogic' },
  { reviewerName: 'Emma V.', reviewerPhotoUrl: null, rating: 5, text: "We have been using PoolLogic for our pool and spa services and had a great experience the entire time. The automated billing is convenient. After every maintenance we receive real time data on the health of our pool. Roni takes care of our pool weekly and is always on time. 10/10 will recommend!", relativeTimeDescription: 'Thumbtack', publishedAt: null, googleReviewUrl: null, placeId: '', businessName: 'PoolLogic' },
  { reviewerName: 'Michelle Nails', reviewerPhotoUrl: null, rating: 5, text: "We recently had issues with our pool automation system. PoolLogic sent a technician who knew exactly what he was doing. He diagnosed the problem, replaced a faulty part, and walked us through how to better use the system. Now everything works from my phone again.", relativeTimeDescription: 'Trustindex', publishedAt: null, googleReviewUrl: null, placeId: '', businessName: 'PoolLogic' },
  { reviewerName: 'Dylan Robert', reviewerPhotoUrl: null, rating: 5, text: "I've tried other pool companies in the past, and none of them compare to PoolLogic. They're reliable, responsive, and always keep me in the loop. I especially love the detailed reports and photos they send after each visit. My pool is in good hands!", relativeTimeDescription: 'Trustindex', publishedAt: null, googleReviewUrl: null, placeId: '', businessName: 'PoolLogic' },
  { reviewerName: 'Anthony Perri', reviewerPhotoUrl: null, rating: 5, text: "I called Pool Logic after my pool in Chula Vista turned cloudy and my pump stopped circulating water properly. Their technician came out the next day, diagnosed the issue, and cleaned out a clogged impeller. Everything was running perfectly again within hours.", relativeTimeDescription: 'Trustindex', publishedAt: null, googleReviewUrl: null, placeId: '', businessName: 'PoolLogic' },
  { reviewerName: 'Wayne H.', reviewerPhotoUrl: null, rating: 5, text: "Great pool service. Our pool water has been crystal clear, starting from the first day of PoolLogic's service.", relativeTimeDescription: 'Thumbtack', publishedAt: null, googleReviewUrl: null, placeId: '', businessName: 'PoolLogic' },
];

// Merge Google + external reviews, interleave for variety
const allReviews: Review[] = [];
const maxExternal = Math.min(externalReviews.length, 10);
let extIdx = 0;
for (let i = 0; i < reviews.length; i++) {
  allReviews.push(reviews[i]);
  // Insert an external review every 2 Google reviews
  if ((i + 1) % 2 === 0 && extIdx < maxExternal) {
    allReviews.push(externalReviews[extIdx++]);
  }
}
// Append remaining external reviews
while (extIdx < maxExternal) {
  allReviews.push(externalReviews[extIdx++]);
}

// Total review count across all sources
const totalAllReviews = totalReviews + externalReviews.length;

// For an infinite-loop marquee we need the content duplicated so the
// translateX animation wraps seamlessly from 0 to -50%.
const marqueeReviews = allReviews.length > 0 ? [...allReviews, ...allReviews] : [];

function getInitials(name: string): string {
  return name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2);
}

function truncateText(text: string, max: number): string {
  if (text.length <= max) return text;
  return text.slice(0, max).replace(/\s+\S*$/, '') + '...';
}

// Pace the marquee: longer duration for more reviews so the scroll stays slow.
const marqueeDuration = Math.max(40, allReviews.length * 6);
---

<section class="py-14 lg:py-20 bg-gradient-to-b from-white to-gray-50">
  <!-- Header (contained) -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-8 sm:mb-12">
      <div class="flex items-center justify-center gap-3 mb-4">
        <!-- Stars -->
        <div class="flex items-center gap-1">
          {[...Array(5)].map(() => (
            <svg class="h-5 w-5 sm:h-6 sm:w-6 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 mb-3 leading-tight">
        Loved by San Diego Pool Owners
      </h2>
      {hasFetched ? (
        <p class="text-base sm:text-lg text-gray-600">
          <span class="font-semibold text-gray-900">{averageRating}</span> out of 5 stars, based on <span class="font-semibold text-gray-900">{totalAllReviews}+</span> verified reviews
        </p>
      ) : (
        <p class="text-base sm:text-lg text-gray-600">
          Read our verified reviews
        </p>
      )}
    </div>
  </div>

  {marqueeReviews.length > 0 ? (
    <!-- Full-width marquee with nav arrows -->
    <div class="relative">
      <!-- Nav arrows -->
      <button
        class="reviews-nav-prev absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 sm:w-12 sm:h-12 bg-white/90 backdrop-blur-sm rounded-full shadow-lg flex items-center justify-center text-gray-600 hover:text-[#00568c] hover:bg-white transition-all"
        aria-label="Previous reviews"
      >
        <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        class="reviews-nav-next absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 sm:w-12 sm:h-12 bg-white/90 backdrop-blur-sm rounded-full shadow-lg flex items-center justify-center text-gray-600 hover:text-[#00568c] hover:bg-white transition-all"
        aria-label="Next reviews"
      >
        <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <div
        class="reviews-marquee group relative overflow-hidden"
        style={`--marquee-duration: ${marqueeDuration}s`}
      >
        <!-- Wider fade edges -->
        <div class="pointer-events-none absolute inset-y-0 left-0 w-16 sm:w-32 lg:w-48 bg-gradient-to-r from-gray-50 to-transparent z-10"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 w-16 sm:w-32 lg:w-48 bg-gradient-to-l from-gray-50 to-transparent z-10"></div>

        <div class="reviews-marquee-track flex gap-5 w-max py-4 px-4">
          {marqueeReviews.map((review, idx) => (
            <div
              class="w-[300px] sm:w-[340px] flex-shrink-0 bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex flex-col"
              aria-hidden={idx >= allReviews.length ? 'true' : 'false'}
            >
              <!-- Reviewer info -->
              <div class="flex items-center gap-3 mb-4">
                {review.reviewerPhotoUrl ? (
                  <img
                    src={review.reviewerPhotoUrl}
                    alt={review.reviewerName}
                    class="w-10 h-10 rounded-full object-cover"
                    loading="lazy"
                    referrerpolicy="no-referrer"
                    onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
                  />
                  <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#00568c] to-[#88d2c7] items-center justify-center text-white font-semibold text-sm hidden">
                    {getInitials(review.reviewerName)}
                  </div>
                ) : (
                  <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#00568c] to-[#88d2c7] flex items-center justify-center text-white font-semibold text-sm">
                    {getInitials(review.reviewerName)}
                  </div>
                )}
                <div class="min-w-0 flex-1">
                  <p class="font-semibold text-gray-900 text-sm truncate">{review.reviewerName}</p>
                  <p class="text-gray-500 text-xs">{review.relativeTimeDescription}</p>
                </div>
                <!-- Source icon -->
                {review.placeId ? (
                  <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                  </svg>
                ) : (
                  <svg class="h-4 w-4 flex-shrink-0 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                )}
              </div>
              <!-- Stars -->
              <div class="flex gap-0.5 mb-3">
                {[...Array(5)].map(() => (
                  <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <!-- Review text -->
              <p class="text-gray-700 text-sm leading-relaxed flex-1">
                {truncateText(review.text, 200)}
              </p>
              {review.text.length > 200 && review.googleReviewUrl && (
                <a
                  href={review.googleReviewUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[#00568c] text-sm font-medium mt-3 inline-block hover:underline"
                >
                  Read more on Google &rarr;
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  ) : (
    <!-- Fallback when no reviews available -->
    <div class="text-center py-8">
      <p class="text-gray-600 mb-4">Check out what our customers are saying</p>
    </div>
  )}

  <!-- Footer CTA -->
  <div class="text-center mt-10">
    <a
      href={googleProfileUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-[#00568c] font-semibold hover:underline"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      {hasFetched ? `See all ${totalReviews} reviews on Google` : 'See our reviews on Google'}
    </a>
  </div>
</section>

<style>
  .reviews-marquee-track {
    animation: reviews-marquee var(--marquee-duration, 60s) linear infinite;
    will-change: transform;
  }

  /* Pause on hover so users can read a card that catches their eye */
  .reviews-marquee:hover .reviews-marquee-track {
    animation-play-state: paused;
  }

  @keyframes reviews-marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - 10px));
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .reviews-marquee-track {
      animation: none;
    }
    .reviews-marquee {
      overflow-x: auto;
      scrollbar-width: thin;
    }
  }
</style>

<script>
  // Manual navigation for review carousel
  document.querySelectorAll('.reviews-nav-prev, .reviews-nav-next').forEach((btn) => {
    btn.addEventListener('click', () => {
      const container = btn.closest('.relative')?.querySelector('.reviews-marquee') as HTMLElement;
      const track = container?.querySelector('.reviews-marquee-track') as HTMLElement;
      if (!container || !track) return;

      // Pause auto-scroll
      track.style.animationPlayState = 'paused';

      // Get current transform position
      const computedStyle = window.getComputedStyle(track);
      const matrix = new DOMMatrix(computedStyle.transform);
      const currentX = matrix.m41;

      // Card width + gap (340px + 20px gap)
      const scrollAmount = btn.classList.contains('reviews-nav-prev') ? 360 : -360;

      // Apply new position
      track.style.animation = 'none';
      track.style.transform = `translateX(${currentX + scrollAmount}px)`;

      // Resume auto-scroll after 5 seconds of inactivity
      clearTimeout((container as any)._resumeTimer);
      (container as any)._resumeTimer = setTimeout(() => {
        track.style.animation = '';
        track.style.transform = '';
        track.style.animationPlayState = '';
      }, 5000);
    });
  });
</script>
