---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faqs?: FAQItem[];
  title?: string;
}

const defaultFAQs: FAQItem[] = [
  {
    question: 'What services do you offer?',
    answer: 'We provide a wide range of pool services, including regular maintenance, cleaning, chemical balancing, and equipment repairs.',
  },
  {
    question: 'How often should I have my pool serviced?',
    answer: 'We recommend weekly service to keep your pool clear and safe year-round.',
  },
  {
    question: 'Do you offer emergency pool repair services?',
    answer: 'Yes, we are happy to help with any emergency repairs for urgent issues such as pump failures, and equipment malfunctions. We do not offer leak detection, although we would be happy to refer you to one of our partners.',
  },
  {
    question: 'Are your technicians certified and insured?',
    answer: 'Yes, all our technicians are certified, experienced, and fully insured for your peace of mind.',
  },
  {
    question: 'Do you provide service contracts or maintenance plans?',
    answer: 'Yes, we offer weekly service contracts and maintenance plans tailored to the needs of your pool.',
  },
  {
    question: 'How do I know if my pool needs a chemical adjustment?',
    answer: "Signs that your pool needs a chemical adjustment include cloudy water, strong chlorine smell, and skin or eye irritation. It is important to keep your pH balanced to avoid harmful algae and bacteria growth. We'd be happy to take care of this for you.",
  },
  {
    question: 'What types of pool equipment do you work with?',
    answer: 'We service all major brands and types of pool equipment, including pumps, filters, heaters, chlorinators, and automation systems. Some of the more common brands we work with include Pentair, Hayward, Jandy, and others.',
  },
];

const {
  faqs = defaultFAQs,
  title = 'Questions? Glad you asked.',
} = Astro.props;
---

<section class="py-16 lg:py-28">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-8 sm:mb-12">
      <p class="text-[#00568c] font-semibold mb-3">FAQ</p>
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900">
        {title}
      </h2>
    </div>

    <!-- FAQ Items -->
    <div class="bg-white rounded-2xl border border-gray-200 px-4 sm:px-8" data-faq-container>
      {faqs.map((faq, index) => (
        <div class="border-b border-gray-200 last:border-0" data-faq-item>
          <button
            class="w-full py-6 flex items-center justify-between text-left hover:text-[#00568c] transition-colors"
            data-faq-trigger
            aria-expanded={index === 0 ? 'true' : 'false'}
          >
            <span class="font-semibold text-base sm:text-lg text-gray-900 pr-4">{faq.question}</span>
            <span
              class:list={[
                'flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center transition-transform',
                index === 0 ? 'rotate-180 bg-[#88d2c7]/20' : 'bg-gray-100',
              ]}
              data-faq-icon
            >
              <svg
                class:list={[
                  'h-5 w-5',
                  index === 0 ? 'text-[#00568c]' : 'text-gray-500',
                ]}
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </button>
          <div
            class:list={[
              'overflow-hidden transition-all duration-300',
              index === 0 ? 'max-h-96 pb-6' : 'max-h-0',
            ]}
            data-faq-panel
          >
            <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Contact prompt -->
    <p class="text-center text-gray-500 mt-8">
      Still have questions?{' '}
      <a href="/about/#contact" class="text-[#00568c] font-medium hover:text-[#00568c]">
        Get in touch
      </a>
    </p>
  </div>
</section>

<script>
  function initFAQ() {
    document.querySelectorAll('[data-faq-container]').forEach((container) => {
      const items = container.querySelectorAll('[data-faq-item]');

      items.forEach((item) => {
        const trigger = item.querySelector('[data-faq-trigger]') as HTMLButtonElement;
        const panel = item.querySelector('[data-faq-panel]') as HTMLElement;
        const icon = item.querySelector('[data-faq-icon]') as HTMLElement;
        const svg = icon?.querySelector('svg') as SVGElement;

        trigger?.addEventListener('click', () => {
          const isOpen = trigger.getAttribute('aria-expanded') === 'true';

          // Close all items
          items.forEach((otherItem) => {
            const otherTrigger = otherItem.querySelector('[data-faq-trigger]') as HTMLButtonElement;
            const otherPanel = otherItem.querySelector('[data-faq-panel]') as HTMLElement;
            const otherIcon = otherItem.querySelector('[data-faq-icon]') as HTMLElement;
            const otherSvg = otherIcon?.querySelector('svg') as SVGElement;

            otherTrigger?.setAttribute('aria-expanded', 'false');
            if (otherPanel) {
              otherPanel.classList.remove('max-h-96', 'pb-6');
              otherPanel.classList.add('max-h-0');
            }
            if (otherIcon) {
              otherIcon.classList.remove('rotate-180', 'bg-[#88d2c7]/20');
              otherIcon.classList.add('bg-gray-100');
            }
            if (otherSvg) {
              otherSvg.classList.remove('text-[#00568c]');
              otherSvg.classList.add('text-gray-500');
            }
          });

          // Toggle clicked item (open if it was closed)
          if (!isOpen) {
            trigger.setAttribute('aria-expanded', 'true');
            if (panel) {
              panel.classList.remove('max-h-0');
              panel.classList.add('max-h-96', 'pb-6');
            }
            if (icon) {
              icon.classList.remove('bg-gray-100');
              icon.classList.add('rotate-180', 'bg-[#88d2c7]/20');
            }
            if (svg) {
              svg.classList.remove('text-gray-500');
              svg.classList.add('text-[#00568c]');
            }
          }
        });
      });
    });
  }

  // Re-initialize after View Transitions navigation
  document.addEventListener('astro:page-load', initFAQ);
</script>
