---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import Button from '@/components/ui/Button.astro';
import { company } from '@/data/company';
import { allCities, metros } from '@/data/cities';

const title = `Pool Service Near Me | ${company.name}`;
const description = `Find professional pool service near you. ${company.name} serves San Diego, Los Angeles, Orange County & Sacramento. ${allCities.length}+ cities covered. Get a free quote today!`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={`${company.url}/pool-service-near-me/`}
  ogTitle={title}
  ogDescription={`Find pool service near you. ${company.name} serves ${allCities.length}+ cities across 4 California metros.`}
  ogUrl={`${company.url}/pool-service-near-me/`}
  keywords={['pool service near me', 'pool cleaning near me', 'pool company near me', 'pool maintenance near me']}
>
  <!-- Breadcrumbs -->
  <div class="py-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs
        items={[
          { name: 'Home', url: '/' },
          { name: 'Pool Service Near Me', url: '/pool-service-near-me/' },
        ]}
      />
    </div>
  </div>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-[#00568c] to-[#00568c]/80 text-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">
          Pool Service Near Me
        </h1>
        <p class="text-xl text-blue-100 mb-8">
          {company.name} provides professional pool cleaning and maintenance across four California metro areas.
          Find your city below and get started with a free quote.
        </p>
        <Button href={company.quoteUrl} external size="lg" variant="secondary">
          Get Your Free Quote
        </Button>
      </div>
    </div>
  </section>

  <!-- Metro Areas -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Our Service Areas
        </h2>
        <p class="text-lg text-gray-600">
          {company.serviceAreaDescription}. {allCities.length}+ cities served.
        </p>
      </div>

      <div class="space-y-12">
        {metros.map((metro) => {
          const hubCity = metro.cities.find(c => c.isPrimary);
          const subCities = metro.cities.filter(c => !c.isPrimary);

          return (
            <div class="bg-gray-50 rounded-2xl p-6 sm:p-8">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
                <div>
                  <h3 class="text-2xl font-bold text-gray-900">{metro.name} Pool Service</h3>
                  <p class="text-gray-600 mt-1">{metro.cities.length} cities served &middot; {metro.phone.display}</p>
                </div>
                {hubCity && (
                  <a
                    href={hubCity.urlPath}
                    class="mt-3 sm:mt-0 inline-flex items-center gap-2 text-[#00568c] font-semibold hover:text-[#00568c]/80 transition-colors"
                  >
                    {metro.name} hub page
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                )}
              </div>

              <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
                {metro.cities.map((city) => (
                  <a
                    href={city.urlPath}
                    class={`block py-2.5 transition-colors ${
                      city.isPrimary
                        ? 'text-[#00568c] font-semibold hover:text-[#00568c]/80'
                        : 'text-gray-700 hover:text-[#00568c]'
                    }`}
                  >
                    {city.name}
                    {city.isPrimary && <span class="text-xs text-gray-400 ml-1">(hub)</span>}
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 lg:py-24 bg-[#00568c]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
        Don&apos;t See Your City?
      </h2>
      <p class="text-xl text-blue-100 mb-8">
        We are expanding rapidly across California. Contact us to check availability in your area.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={company.quoteUrl} external size="lg" variant="secondary">
          Check Availability
        </Button>
        <Button href={`tel:${company.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-[#00568c]">
          <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          Call {company.phone}
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
