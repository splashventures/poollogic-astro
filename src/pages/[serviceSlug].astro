---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { company } from '@/data/company';
import { services, getServiceBySlug } from '@/data/services';
import Button from '@/components/ui/Button.astro';
import FAQ from '@/components/ui/FAQ.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { serviceSlug: service.urlSlug },
    props: { service },
  }));
}

const { service } = Astro.props;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: service.name, url: `/${service.urlSlug}/` },
];

const relatedServiceObjects = service.relatedServices
  .map((slug) => getServiceBySlug(slug))
  .filter((s): s is NonNullable<typeof s> => s != null);

const categoryLabel =
  service.category === 'maintenance'
    ? 'Maintenance'
    : service.category === 'repair'
      ? 'Repair'
      : 'Installation';
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDescription}
  canonical={`${company.url}/${service.urlSlug}/`}
  ogTitle={service.metaTitle}
  ogDescription={service.metaDescription}
  ogUrl={`${company.url}/${service.urlSlug}/`}
  keywords={service.keywords}
>
  <!-- Breadcrumbs -->
  <div class="bg-gray-50 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-brand-blue">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-24">
      <div class="max-w-3xl">
        <span class="inline-block bg-white/15 backdrop-blur-sm text-white text-sm font-medium px-3 py-1 rounded-full mb-4">
          {categoryLabel}
        </span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-6">
          {service.name}
        </h1>
        <p class="text-lg sm:text-xl text-blue-100 leading-relaxed mb-8">
          {service.shortDescription}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href={company.quoteUrl} external size="lg" variant="secondary">
            Get a Free Quote
          </Button>
          <Button href={`tel:${company.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-brand-blue">
            <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
            </svg>
            {company.phone}
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Long Description -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-6">
          About Our {service.name} Service
        </h2>
        <div class="prose prose-lg text-gray-600 leading-relaxed">
          <p>{service.longDescription}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-brand-blue font-semibold mb-3">WHAT WE DO</p>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900">
          Service Features
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {service.features.map((feature) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="w-10 h-10 bg-brand-blue/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">{feature.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-10">
          <p class="text-brand-blue font-semibold mb-3">WHAT&apos;S INCLUDED</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">
            Everything You Get with {service.name}
          </h2>
        </div>

        <ul class="space-y-4">
          {service.includes.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700 text-lg">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-24 bg-brand-blue">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-6">
        Ready to Get Started with {service.name}?
      </h2>
      <p class="text-lg text-blue-100 mb-8 max-w-2xl mx-auto">
        Get a free, no-obligation quote. Our team will have a custom plan ready for you within minutes.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={company.quoteUrl} external size="lg" variant="secondary">
          Get Your Free Quote
        </Button>
        <Button href={`tel:${company.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-brand-blue">
          <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          Call {company.phone}
        </Button>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {relatedServiceObjects.length > 0 && (
    <section class="py-16 lg:py-24 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <p class="text-brand-blue font-semibold mb-3">RELATED SERVICES</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">
            You Might Also Need
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {relatedServiceObjects.map((related) => (
            <a
              href={`/${related.urlSlug}/`}
              class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md hover:border-brand-sky/30 transition-all group"
            >
              <h3 class="font-semibold text-gray-900 group-hover:text-brand-blue transition-colors mb-2">
                {related.name}
              </h3>
              <p class="text-sm text-gray-600 line-clamp-2">{related.shortDescription}</p>
              <span class="inline-flex items-center text-sm text-brand-blue font-medium mt-3 group-hover:gap-2 transition-all">
                Learn more
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <FAQ />
</BaseLayout>
