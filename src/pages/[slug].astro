    { number: '3', title: 'Enjoy the Results', description: `Your ${service.category === 'maintenance' ? 'pool is clean, balanced, and swim-ready' : 'equipment works like new'}. We guarantee your satisfaction.`, image: '/images/pool/step-enjoy-pool.webp', imageAlt: 'Beautiful crystal clear pool', highlight: '100% satisfaction guaranteed' },
  ];
}

// === Service FAQs ===

function getServiceFAQs(service: Service) {
  return [
    { question: `How much does ${service.name.toLowerCase()} cost?`, answer: `Contact us for a free, no-obligation quote. Final pricing depends on your specific pool and equipment. Every quote includes a detailed breakdown with no hidden fees.` },
    { question: `How long does ${service.name.toLowerCase()} take?`, answer: `The duration depends on your pool's size and condition. Most ${service.category} services are completed in a single visit. We'll provide a time estimate when we assess your specific situation.` },
    { question: `Do you offer ${service.name.toLowerCase()} in my area?`, answer: `We provide ${service.name.toLowerCase()} throughout San Diego County, including San Diego, Chula Vista, Carlsbad, La Jolla, Escondido, and 20+ other cities across greater San Diego.` },
    { question: `Why should I choose PoolLogic for ${service.name.toLowerCase()}?`, answer: `With ${company.yearsInBusiness}+ years of experience and ${company.rating.count}+ 5-star reviews, we're San Diego's trusted pool service provider. We use quality parts, provide written estimates, and stand behind our work.` },
    { question: `How do I schedule ${service.name.toLowerCase()}?`, answer: `Request a free quote online or call us at ${company.phone}. We'll discuss your needs, provide a custom quote, and schedule a convenient appointment.` },
  ];
}

// === Static paths ===

export const getStaticPaths = (async () => {
  const cityParams = cities.map((city) => ({
    params: { slug: `pool-service-${city.slug}` },
    props: { type: 'city' as const, city, service: undefined as Service | undefined },
  }));

  const serviceParams = services.map((service) => ({
    params: { slug: service.urlSlug },
    props: { type: 'service' as const, service, city: undefined as City | undefined },
  }));

  const comboParams = getAllComboParams().map((p) => {
    const combo = parseComboSlug(p.slug);
    if (!combo) return null;
    const svcUrl = getServiceUrlSlugFromComboSlug(combo.serviceSlug);
    const svc = getServiceByUrlSlug(svcUrl);
    const city = getCityBySlug(combo.citySlug);
    if (!svc || !city) return null;
    return {
      params: { slug: p.slug },
      props: { type: 'combo' as const, service: svc, city },
    };
  }).filter(Boolean) as { params: { slug: string }; props: { type: 'combo'; service: Service; city: City } }[];

  return [...cityParams, ...serviceParams, ...comboParams];
}) satisfies GetStaticPaths;

// === Resolve props ===

const { type, city, service } = Astro.props;

// === Build metadata based on page type ===

let pageTitle = '';
let pageDescription = '';
let pageCanonical = '';
let pageKeywords: string[] = [];
let pageOgTitle = '';
let pageOgDescription = '';
let pageGeoRegion = 'US-CA';
let pageGeoPlacename = 'San Diego';
let pageGeoPosition = `${company.coordinates.lat};${company.coordinates.lng}`;
let schemas: object[] = [];

if (type === 'city' && city) {
  pageTitle = `${city.name} Pool Service | #1 Rated Pool Cleaning | PoolLogic`;
  pageDescription = `${city.name} pool service & cleaning by CPO-certified technicians. Weekly maintenance, all chemicals included. ${company.rating.count}+ 5-star reviews. Call ${company.phone}!`;
  pageCanonical = `${company.url}/pool-service-${city.slug}/`;
  pageKeywords = [
    `pool service ${city.name}`, `${city.name} pool service`, `pool cleaning ${city.name}`,
    `${city.name} pool cleaning`, `pool service ${city.name} CA`, `pool maintenance ${city.name}`,
    `pool service near me ${city.name}`, `pool company ${city.name}`, `best pool service ${city.name}`,
  ];
  pageOgTitle = `${city.name} Pool Service & Cleaning | PoolLogic Pool Service`;
  pageOgDescription = `Professional pool service in ${city.name}, CA. Weekly cleaning, repairs & maintenance. Trusted by ${company.rating.count}+ families. Free quotes!`;
  pageGeoPlacename = city.name;
  pageGeoPosition = `${city.coordinates.lat};${city.coordinates.lng}`;

  const localBusinessSchema = generateCityLocalBusinessSchema(city);
  schemas.push(localBusinessSchema);
  const cityFaqs = city.faqs;
  const faqSchema = generateSimpleFAQSchema(cityFaqs);
  if (faqSchema) schemas.push(faqSchema);
  const speakableSchema = generateSpeakableSchema(`${company.url}/pool-service-${city.slug}/`);
  schemas.push(speakableSchema);
} else if (type === 'service' && service) {
  pageTitle = `${service.name} | San Diego Pool Service | PoolLogic Pool Service`;
  pageDescription = `Professional ${service.name} in San Diego. ${service.longDescription.slice(0, 100)}... ${company.rating.count}+ reviews. Call ${company.phone}!`;
  pageCanonical = `${company.url}/${service.urlSlug}/`;
  pageKeywords = [
    ...service.keywords,
    `${service.name.toLowerCase()} near me`,
    `${service.name.toLowerCase()} san diego`,
    `${service.name.toLowerCase()} chula vista`,
    `${service.name.toLowerCase()} carlsbad`,
    `pool ${service.category} service`,
  ];
  pageOgTitle = pageTitle;
  pageOgDescription = pageDescription;

  const serviceSchema = generateServiceSchema(service);
  schemas.push(serviceSchema);
  const svcSteps = getServiceSteps(service);
  const howToSchema = generateHowToSchema(service, svcSteps);
  schemas.push(howToSchema);
  const svcFaqs = getServiceFAQs(service);
  const faqSchema = generateSimpleFAQSchema(svcFaqs);
  if (faqSchema) schemas.push(faqSchema);
  const speakableSchema = generateSpeakableSchema(`${company.url}/${service.urlSlug}/`);
  schemas.push(speakableSchema);
} else if (type === 'combo' && service && city) {
  const comboSlug = getComboUrlSlug(service, city);
  pageTitle = `${service.name} in ${city.name}, CA | ${company.name}`;
  pageDescription = `Professional ${service.name.toLowerCase()} in ${city.name}, San Diego County. CPO-certified technicians, ${company.rating.count}+ 5-star reviews. Call ${company.phone} for a free quote!`;
  pageCanonical = `${company.url}/${comboSlug}/`;
  pageKeywords = [
    `${service.name.toLowerCase()} ${city.name.toLowerCase()}`,
    `pool service ${city.name.toLowerCase()}`,
    `${service.name.toLowerCase()} near me`,
    ...service.keywords.slice(0, 3),
  ];
  pageOgTitle = pageTitle;
  pageOgDescription = pageDescription;
  pageGeoPlacename = city.name;
  pageGeoPosition = `${city.coordinates.lat};${city.coordinates.lng}`;

  const serviceSchema = generateServiceSchema(service);
  schemas.push(serviceSchema);
  const comboFaqs = getComboFAQs(service, city);
  const faqSchema = generateSimpleFAQSchema(comboFaqs);
  if (faqSchema) schemas.push(faqSchema);
}

// === City page data ===
const nearbyCities = city ? getNearbyCities(city.slug) : [];
const cityFaqs = (type === 'city' && city) ? city.faqs : [];

// Returns the distance-from-HQ text to display, or null if it should be hidden
// (San Diego itself is HQ, and cities > 10 miles away shouldn't emphasize distance).
function getDistanceText(c: City | undefined): string | null {
  if (!c) return null;
  if (c.distanceFromHQ === 'Headquarters') return null;
  const match = c.distanceFromHQ.match(/(\d+)/);
  if (!match) return null;
  const miles = parseInt(match[1], 10);
  if (miles > 10) return null;
  return c.distanceFromHQ;
}
const distanceText = getDistanceText(city);

// === Service page data ===
const serviceFaqs = (type === 'service' && service) ? getServiceFAQs(service) : [];
const primaryCities = getPrimaryCities().slice(0, 12);
const relatedServices = (type === 'service' && service)
  ? (service.relatedServices?.map((s) => getServiceBySlug(s)).filter(Boolean) as Service[])
  : [];

