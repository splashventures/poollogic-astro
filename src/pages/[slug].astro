      { number: '1', title: 'Tell Us Your Filtration Needs', description: "We evaluate your pool volume, usage, and water quality goals to recommend the right filter type (cartridge, sand, or DE) and provide a quote.", image: '/images/pool/phone.jpg', imageAlt: 'Getting a quote for pool filter installation', highlight: 'Right filter for your pool' },
