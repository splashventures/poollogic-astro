---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { company } from '@/data/company';
import { services } from '@/data/services';
import { reviews } from '@/data/reviews';
import { formatPhoneLink } from '@/lib/utils';

const title = `Pool Service San Diego | ${company.name}`;
const description = `Stop worrying about your pool. ${company.name} provides professional pool cleaning, maintenance, and repairs in San Diego. ${company.poolsServed.toLocaleString()}+ satisfied customers. 100% satisfaction guarantee.`;

const valueProps = [
  {
    title: 'Easy & Transparent Setup',
    description: 'Schedule your pool service in just 5 minutes. CPO-certified technicians, all chemicals included.',
    iconPath: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Full Service',
    description: 'Pool cleaning, equipment repairs, equipment installations, and everything in between. We handle it all.',
    iconPath: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    title: '100% Satisfaction Guarantee',
    description: "If you aren't happy with our service, we'll give your money back. No questions asked.",
    iconPath: 'M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5',
  },
];

const trustSignals = [
  { title: 'Bonded & Insured', description: 'Multimillion dollar liability insurance policy for your peace of mind.' },
  { title: 'Professional Team', description: 'Professionally trained to the highest skill level in the industry.' },
  { title: 'Customer Support', description: 'Chat, email, and phone support available whenever you need us.' },
];

const featuredReviews = reviews.slice(5, 8);
---

<BaseLayout
  title={title}
  description={description}
  noindex={true}
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-[#00568c] to-[#00568c]/80 text-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl lg:text-5xl font-bold mb-6">Stop Worrying About Your Pool</h1>
        <p class="text-xl text-blue-100 mb-8">
          Crystal clear pool water, year-round. Professional pool service you can count on.
        </p>
        <Button href={company.quoteUrl} external size="lg" class="text-lg px-8 py-4">
          See My Price
        </Button>
        <p class="text-blue-200 mt-4 text-sm">Free quote in under 2 minutes</p>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-gray-900 text-white py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-3xl font-bold text-[#88d2c7]">{company.poolsServed.toLocaleString()}+</p>
          <p class="text-gray-400 text-sm">Satisfied Customers</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-[#88d2c7]">{company.rating.count}+</p>
          <p class="text-gray-400 text-sm">Customer Reviews</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-[#88d2c7]">{company.rating.value}</p>
          <p class="text-gray-400 text-sm">Star Rating</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-[#88d2c7]">{company.yearsInBusiness}+</p>
          <p class="text-gray-400 text-sm">Years Experience</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Props -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {valueProps.map((prop) => (
          <div class="text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-[#00568c]/10 text-[#00568c] rounded-2xl mb-4">
              <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={prop.iconPath} />
              </svg>
            </div>
            <h2 class="text-xl font-semibold text-gray-900 mb-3">{prop.title}</h2>
            <p class="text-gray-600">{prop.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Complete Pool Care Services</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {services.map((service) => (
          <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
            <p class="font-medium text-gray-900 text-sm">{service.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">
        Why Choose {company.name}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {trustSignals.map((signal) => (
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">{signal.title}</h3>
              <p class="text-gray-600 text-sm">{signal.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Trusted by San Diego Families</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {featuredReviews.map((review) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6">
            <div class="flex gap-0.5 mb-4">
              {Array.from({ length: 5 }).map(() => (
                <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">
              &ldquo;{review.text}&rdquo;
            </p>
            <p class="font-semibold text-gray-900">{review.customerName}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-16 lg:py-24 bg-[#00568c] text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Get Your Pool Taken Care of Today</h2>
      <p class="text-xl text-blue-100 mb-8">
        Join {company.poolsServed.toLocaleString()}+ San Diego families who trust {company.name}.
      </p>
      <Button href={company.quoteUrl} external size="lg" class="text-lg px-8 py-4">
        See My Price
      </Button>
      <p class="text-blue-200 mt-4">
        or call{' '}
        <a href={formatPhoneLink(company.phone)} class="text-white font-semibold underline">
          {company.phone}
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
