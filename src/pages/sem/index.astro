---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { company } from '@/data/company';

const title = `Pool Service in California | ${company.name}`;
const description = `Professional pool cleaning and maintenance. All chemicals included. ${company.rating.count}+ 5-star reviews. Get a free quote in under 2 minutes.`;
---

<BaseLayout
  title={title}
  description={description}
  noindex={true}
>
  <!-- Hero Section - Strong CTA focused -->
  <section class="bg-gradient-to-br from-[#00568c] to-[#00568c]/80 text-white py-20 lg:py-32">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Trust badge -->
      <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-6">
        <div class="flex">
          {Array.from({ length: 5 }).map(() => (
            <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <span class="text-white font-medium text-sm">
          {company.rating.value}/5 from {company.rating.count}+ reviews
        </span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
        Professional Pool Service
        <span class="block text-[#88d2c7]">All Chemicals Included</span>
      </h1>

      <p class="text-xl lg:text-2xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Weekly pool cleaning by CPO-certified technicians. Same tech every week,
        digital service reports, and no hidden fees.
      </p>

      <!-- Value props -->
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-3 mb-10 text-white/90">
        {['All chemicals included', 'CPO-certified techs', 'Same-day service reports', 'Cancel anytime'].map((prop) => (
          <div class="flex items-center gap-2">
            <svg class="h-5 w-5 text-[#88d2c7]" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span>{prop}</span>
          </div>
        ))}
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={company.quoteUrl} external size="lg" variant="secondary">
          Get Your Free Quote
        </Button>
        <Button href={`tel:${company.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-[#00568c]">
          <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          Call {company.phone}
        </Button>
      </div>

      <p class="text-blue-200 text-sm mt-6">
        Free quote in under 2 minutes. No obligation.
      </p>
    </div>
  </section>

  <!-- What You Get -->
  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">
        What You Get with {company.name}
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { title: 'Weekly Pool Cleaning', description: 'Chemical testing, skimming, brushing, vacuuming, and equipment checks every single week.' },
          { title: 'All Chemicals Included', description: 'Chlorine, acid, stabilizer, and specialty chemicals are all included in your service price.' },
          { title: 'Digital Service Reports', description: 'After every visit, you receive a detailed report with photos, chemical readings, and notes.' },
          { title: 'Same Technician Weekly', description: 'Your dedicated technician knows your pool inside and out. Consistent care, consistent results.' },
          { title: 'Equipment Monitoring', description: 'We check your pump, filter, heater, and other equipment every visit and flag issues early.' },
          { title: 'Priority Repairs', description: 'If something breaks, our service customers get priority scheduling at preferred rates.' },
        ].map((item) => (
          <div class="flex items-start gap-4">
            <svg class="h-6 w-6 text-[#00568c] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <h3 class="font-semibold text-gray-900">{item.title}</h3>
              <p class="text-gray-600 text-sm mt-1">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-16 lg:py-24 bg-[#00568c]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
        Ready for Crystal-Clear Water?
      </h2>
      <p class="text-xl text-blue-100 mb-8">
        Join {company.poolsServed.toLocaleString()}+ happy customers. Get your free quote today.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={company.quoteUrl} external size="lg" variant="secondary">
          Get Your Free Quote
        </Button>
        <Button href={`tel:${company.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-[#00568c]">
          <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          Call {company.phone}
        </Button>
      </div>
      <p class="text-blue-200 text-sm mt-4">
        Bonded &amp; Insured &middot; Licensed Contractors &middot; {company.rating.count}+ 5-Star Reviews
      </p>
    </div>
  </section>
</BaseLayout>
