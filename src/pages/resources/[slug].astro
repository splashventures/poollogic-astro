---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { posts, getPostBySlug, getRelatedPosts } from '@/data/posts';
import { company } from '@/data/company';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import DualCTA from '@/components/ui/DualCTA.astro';
import { generateArticleSchema } from '@/lib/schema/article';
import { generateSimpleFAQSchema } from '@/lib/schema/faq';

export const getStaticPaths = (async () => {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const relatedPosts = getRelatedPosts(post);
const articleSchema = generateArticleSchema(post);
const faqSchema = generateSimpleFAQSchema(post.faqs);
const schemas = [articleSchema, ...(faqSchema ? [faqSchema] : [])];

const FALLBACK_IMAGE = '/images/pool/hero-pool.webp';
const FALLBACK_IMAGE_ALT = 'PoolLogic professional pool service in San Diego';

const categoryPath = `/resources/category/${post.category}/`;
const categoryLabel = post.categoryName;
const postUrl = `${company.url}/resources/${post.slug}/`;
---

<BaseLayout
  title={`${post.title} | ${company.name}`}
  description={post.excerpt}
  canonical={postUrl}
  ogTitle={post.title}
  ogDescription={post.excerpt}
  ogType="article"
  ogUrl={postUrl}
  schemas={schemas}
>
  <!-- Breadcrumbs -->
  <div class="py-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs
        items={[
          { name: 'Home', url: '/' },
          { name: 'Resources', url: '/resources/' },
          { name: post.title, url: `/resources/${post.slug}/` },
        ]}
      />
    </div>
  </div>

  <!-- Article Header -->
  <header class="bg-gradient-to-br from-[#00568c] to-[#00568c]/80 text-white py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <a
        href={categoryPath}
        class="inline-flex items-center gap-1 text-sm font-medium text-[#88d2c7] hover:text-[#88d2c7]/80 mb-4"
      >
        {categoryLabel}
      </a>
      <h1 class="text-3xl lg:text-4xl font-bold mb-4">{post.title}</h1>
      <div class="flex flex-wrap items-center gap-4 text-blue-200 text-sm">
        <a href="/about/kyle-bowman/" class="inline-flex items-center gap-2 hover:text-white transition-colors">
          <img
            src="/images/pool/kyle-bowman.webp"
            alt={post.author}
            width="28"
            height="28"
            class="rounded-full object-cover"
          />
          By {post.author}
        </a>
        <span class="hidden sm:inline">&middot;</span>
        <time datetime={post.date}>
          {new Date(post.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <span class="hidden sm:inline">&middot;</span>
        <span>{post.readTime}</span>
      </div>
    </div>
  </header>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
      <!-- Table of Contents - Sidebar -->
      {post.headings.length > 0 && (
        <aside class="hidden lg:block lg:col-span-1">
          <div class="sticky top-32">
            <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-4">
              Table of Contents
            </h2>
            <nav>
              <ul class="space-y-2 text-sm">
                {post.headings.map((heading, index) => (
                  <li>
                    <a
                      href={`#section-${index}`}
                      class="text-gray-500 hover:text-[#00568c] transition-colors"
                    >
                      {heading}
                    </a>
                  </li>
                ))}
                {post.faqs.length > 0 && (
                  <li>
                    <a
                      href="#faqs"
                      class="text-gray-500 hover:text-[#00568c] transition-colors"
                    >
                      FAQs
                    </a>
                  </li>
                )}
              </ul>
            </nav>
          </div>
        </aside>
      )}

      <!-- Article Content -->
      <article class={post.headings.length > 0 ? 'lg:col-span-3' : 'lg:col-span-4 max-w-4xl'}>
        <!-- Mobile TOC -->
        {post.headings.length > 0 && (
          <div class="lg:hidden bg-gray-50 rounded-xl p-6 mb-8">
            <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-3">
              Table of Contents
            </h2>
            <ul class="space-y-2 text-sm">
              {post.headings.map((heading, index) => (
                <li>
                  <a
                    href={`#section-${index}`}
                    class="text-[#00568c] hover:text-[#00568c]/80"
                  >
                    {heading}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Featured Image -->
        <div class="relative w-full aspect-video rounded-xl overflow-hidden mb-8">
          <img
            src={post.image || FALLBACK_IMAGE}
            alt={post.imageAlt || FALLBACK_IMAGE_ALT}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>

        <!-- Content Sections -->
        <div class="prose max-w-none">
          {post.content.map((section, index) => (
            <section
              id={`section-${index}`}
              class="mb-8"
              set:html={section}
            />
          ))}
        </div>

        <!-- FAQs -->
        {post.faqs.length > 0 && (
          <section id="faqs" class="mt-12 pt-8 border-t border-gray-200">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">
              Frequently Asked Questions
            </h2>
            <div class="space-y-6">
              {post.faqs.map((faq) => (
                <div class="bg-gray-50 rounded-xl p-6">
                  <h3 class="text-lg font-semibold text-gray-900 mb-3">
                    {faq.question}
                  </h3>
                  <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Author Bio -->
        <section class="mt-12 border-t border-gray-200 pt-8">
          <div class="flex items-start gap-4">
            <div class="w-16 h-16 rounded-full overflow-hidden flex-shrink-0">
              <img
                src="/images/pool/kyle-bowman.webp"
                alt="Kyle Bowman"
                width="128"
                height="128"
                class="w-full h-full object-cover"
              />
            </div>
            <div>
              <a href="/about/kyle-bowman/" class="text-lg font-semibold text-gray-900 hover:text-[#00568c] transition-colors">
                Kyle Bowman
              </a>
              <p class="text-sm text-[#00568c] font-medium mb-2">Founder of PoolLogic &middot; CPO-Certified</p>
              <p class="text-gray-600 text-sm leading-relaxed">
                Kyle is the Founder of PoolLogic Pool Service and a Certified Pool Operator (CPO) with deep expertise in pool service, water chemistry, and pool equipment repair. He oversees every aspect of PoolLogic's operations to ensure San Diego pool owners receive expert-level care.
              </p>
            </div>
          </div>
        </section>

        <!-- CTA -->
        <section class="mt-12 bg-[#88d2c7]/10 rounded-2xl p-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">
            Need Professional Pool Service?
          </h2>
          <p class="text-gray-600 mb-6">
            {company.name} provides expert pool cleaning, maintenance, and repair services throughout San Diego County.
          </p>
          <DualCTA quoteText="Get a Free Quote" variant="compact" />
        </section>
      </article>
    </div>
  </div>

  <!-- Related Articles -->
  {relatedPosts.length > 0 && (
    <section class="py-12 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">Related Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map((related) => (
            <a
              href={`/resources/${related.slug}/`}
              class="bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-lg transition-shadow group"
            >
              <div class="relative w-full aspect-video overflow-hidden">
                <img
                  src={related.image || FALLBACK_IMAGE}
                  alt={related.imageAlt || related.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <span class="text-xs font-medium text-[#00568c] uppercase tracking-wide">
                  {related.categoryName}
                </span>
                <h3 class="text-lg font-semibold text-gray-900 mt-2 mb-2 group-hover:text-[#00568c] transition-colors">
                  {related.title}
                </h3>
                <p class="text-gray-600 text-sm line-clamp-2">{related.excerpt}</p>
                <div class="mt-3 text-sm text-gray-500">{related.readTime}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
