---
import { Image } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { topicGroups } from '@/data/posts';
import { topicHubs, getTopicHub } from '@/data/topic-hubs';
import { services } from '@/data/services';
import { company } from '@/data/company';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import DualCTA from '@/components/ui/DualCTA.astro';
import { getImage } from '@/lib/images';

export const getStaticPaths = (async () => {
  return topicHubs.map((hub) => {
    const group = topicGroups.find((g) => g.slug === hub.slug);
    return {
      params: { slug: hub.slug },
      props: { hub, group },
    };
  });
}) satisfies GetStaticPaths;

const { hub, group } = Astro.props;

const FALLBACK_IMAGE = '/images/pool/hero-pool.webp';

const sortedPosts = group
  ? [...group.posts].sort(
      (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
    )
  : [];

const relatedServices = hub.relatedServiceSlugs
  .map((urlSlug: string) => services.find((s) => s.urlSlug === urlSlug))
  .filter((s): s is NonNullable<typeof s> => s !== undefined);

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: hub.name,
  description: hub.metaDescription,
  url: `${company.url}/resources/topic/${hub.slug}/`,
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${company.url}/#website`,
    name: company.name,
  },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: sortedPosts.length,
    itemListElement: sortedPosts.map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `${company.url}/resources/${post.slug}/`,
      name: post.title,
    })),
  },
};
---

<BaseLayout
  title={hub.metaTitle}
  description={hub.metaDescription}
  canonical={`${company.url}/resources/topic/${hub.slug}/`}
  ogTitle={hub.metaTitle}
  ogDescription={hub.metaDescription}
  ogUrl={`${company.url}/resources/topic/${hub.slug}/`}
  schemas={[collectionSchema]}
>
  <!-- Breadcrumbs -->
  <div class="py-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs
        items={[
          { name: 'Home', url: '/' },
          { name: 'Resources', url: '/resources/' },
          { name: hub.name, url: `/resources/topic/${hub.slug}/` },
        ]}
      />
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-[#00568c] to-[#00568c]/80 text-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl lg:text-4xl font-bold mb-4">{hub.name} Guides & Tips</h1>
      <p class="text-xl text-blue-100 max-w-2xl">{hub.heroDescription}</p>
      <p class="text-blue-200 mt-4">{sortedPosts.length} articles</p>
    </div>
  </section>

  <!-- Intro Content -->
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg text-gray-600">
        {hub.introContent.split('\n\n').map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- Articles Grid -->
  <section class="py-12 lg:py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">
        All {hub.name} Articles
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPosts.map((post) => (
          <a
            href={`/resources/${post.slug}/`}
            class="bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-lg transition-shadow group"
          >
            <div class="relative w-full aspect-video overflow-hidden">
              {getImage(post.image || FALLBACK_IMAGE) ? (
                <Image
                  src={getImage(post.image || FALLBACK_IMAGE)!}
                  alt={post.imageAlt || post.title}
                  width={800}
                  height={450}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              ) : (
                <img
                  src={post.image || FALLBACK_IMAGE}
                  alt={post.imageAlt || post.title}
                  width="800"
                  height="450"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              )}
            </div>
            <div class="p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-[#00568c] transition-colors">
                {post.title}
              </h3>
              <p class="text-gray-600 text-sm mb-3 line-clamp-2">{post.excerpt}</p>
              <div class="flex items-center gap-3 text-xs text-gray-500">
                <span>{post.author}</span>
                <span>&middot;</span>
                <time datetime={post.date}>
                  {new Date(post.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
                <span>&middot;</span>
                <span>{post.readTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {relatedServices.length > 0 && (
    <section class="py-12 lg:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">
          Related Services
        </h2>
        <p class="text-gray-600 mb-8">
          Need professional help? We offer these {hub.name.toLowerCase()}-related services across San Diego County.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedServices.map((service) => (
            <a
              href={`/${service.urlSlug}/`}
              class="group bg-white rounded-xl border border-gray-200 p-6 hover:border-[#00568c]/30 hover:shadow-lg transition-all"
            >
              <h3 class="font-bold text-gray-900 group-hover:text-[#00568c] transition-colors mb-2">
                {service.name}
              </h3>
              <p class="text-sm text-gray-600 mb-4 line-clamp-2">
                {service.shortDescription}
              </p>
              <span class="inline-flex items-center text-sm font-semibold text-[#00568c]">
                Learn more
                <svg class="ml-1 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Browse Other Topics -->
  <section class="py-12 lg:py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Explore Other Topics</h2>
      <div class="flex flex-wrap gap-3">
        {topicGroups
          .filter((g) => g.slug !== hub.slug)
          .map((g) => (
            <a
              href={`/resources/topic/${g.slug}/`}
              class="inline-flex items-center gap-2 bg-white border border-gray-200 rounded-full px-4 py-2 text-sm font-medium text-gray-700 hover:border-[#00568c] hover:text-[#00568c] transition-colors"
            >
              {g.name}
              <span class="text-xs text-gray-400">{g.posts.length}</span>
            </a>
          ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-[#88d2c7]/10 rounded-2xl p-8 lg:p-12 text-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">
          Need Professional Pool Help?
        </h2>
        <p class="text-gray-600 mb-8 max-w-2xl mx-auto">
          Whether you need weekly maintenance or a one-time repair, our CPO-certified technicians
          are ready to help. Serving 24 cities across San Diego County.
        </p>
        <DualCTA quoteText="Get a Free Quote" class="justify-center" />
      </div>
    </div>
  </section>

  <!-- Back to Resources -->
  <section class="py-8 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <a
        href="/resources/"
        class="inline-flex items-center gap-2 text-[#00568c] font-semibold hover:text-[#00568c]/80 transition-colors"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to All Resources
      </a>
    </div>
  </section>
</BaseLayout>
