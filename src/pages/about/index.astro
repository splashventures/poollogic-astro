---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import Button from '@/components/ui/Button.astro';
import { company } from '@/data/company';
import { cities } from '@/data/cities';
import { values, milestones, teamMembers, whyChooseUs } from '@/data/brand';

// Load team images from src/assets for Astro Image optimization
const teamImageModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/team/*.webp',
  { eager: true }
);
const poolImageModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/pool/kyle-bowman.webp',
  { eager: true }
);
const allImages = { ...teamImageModules, ...poolImageModules };

function getTeamImage(publicPath: string): ImageMetadata | undefined {
  // Convert public path like "/images/team/jake.webp" to asset path "/src/assets/images/team/jake.webp"
  const assetPath = `/src/assets${publicPath}`;
  // Also handle "/images/pool/kyle-bowman.webp" -> "/src/assets/images/pool/kyle-bowman.webp"
  return allImages[assetPath]?.default;
}

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${company.url}/#organization`,
  name: company.name,
  url: company.url,
  logo: `${company.url}/images/logos/poollogic-logo.png`,
  foundingDate: '2020',
  founder: {
    '@type': 'Person',
    '@id': `${company.url}/about/kyle-bowman/#person`,
    name: 'Kyle Bowman',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: company.address.street,
    addressLocality: company.address.city,
    addressRegion: company.address.state,
    postalCode: company.address.zip,
    addressCountry: 'US',
  },
  telephone: company.phone,
  email: company.email,
  sameAs: [
    company.social.facebook,
    company.social.instagram,
    company.social.yelp,
    company.social.google,
  ],
  areaServed: {
    '@type': 'State',
    name: 'California',
  },
  numberOfEmployees: {
    '@type': 'QuantitativeValue',
    value: teamMembers.length,
  },
};

const title = 'About Us | San Diego Pool Service Experts | PoolLogic Pool Service';
const description = `Learn about PoolLogic Pool Service - ${company.yearsInBusiness}+ years serving San Diego. Locally operated pool service with ${company.rating.count}+ 5-star reviews. Based in San Diego, CA.`;
---

<BaseLayout
  title={title}
  description={description}
  ogTitle={title}
  ogDescription={`Learn about PoolLogic Pool Service - ${company.yearsInBusiness}+ years serving San Diego.`}
  ogUrl="https://poollogicsd.com/about/"
  canonical="https://poollogicsd.com/about/"
  schemas={[organizationSchema]}
>
  <!-- Breadcrumbs -->
  <div class="py-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs
        items={[
          { name: 'Home', url: '/' },
          { name: 'About Us', url: '/about/' },
        ]}
      />
    </div>
  </div>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-[#00568c] to-[#00568c]/80 text-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl lg:text-5xl font-bold mb-4">
            Your Local Pool Care Experts
          </h1>
          <p class="text-xl text-blue-100 mb-6">
            For over {company.yearsInBusiness} years, PoolLogic Pool Service has been San Diego's
            trusted choice for pool cleaning, maintenance, and repair. We're proud to be
            a locally-operated business serving our community.
          </p>
          <div class="flex flex-wrap items-center gap-6">
            <div>
              <div class="text-3xl font-bold">5.0 &#9733;</div>
              <div class="text-blue-200">Google Rating</div>
            </div>
            <div>
              <div class="text-3xl font-bold">{company.poolsServed.toLocaleString()}+</div>
              <div class="text-blue-200">Happy Customers</div>
            </div>
            <div>
              <div class="text-3xl font-bold">{cities.length}+</div>
              <div class="text-blue-200">Cities Served</div>
            </div>
          </div>
        </div>

        <!-- Team Headshots Grid -->
        <div class="grid grid-cols-4 gap-3">
          {teamMembers.map((member) => {
            const imageSrc = getTeamImage(member.src);
            return (
              <div class="text-center">
                <div class="w-full aspect-square rounded-full overflow-hidden mb-1.5">
                  {imageSrc ? (
                    <Image
                      src={imageSrc}
                      alt={`${member.name} - PoolLogic team member`}
                      width={200}
                      height={200}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <img
                      src={member.src}
                      alt={`${member.name} - PoolLogic team member`}
                      width="200"
                      height="200"
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  )}
                </div>
                <p class="text-xs text-blue-200 font-medium">{member.name}</p>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <!-- Our Story -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center">Our Story</h2>
        <div class="prose prose-lg max-w-none text-gray-600">
          <p>
            In 2020, Kyle Bowman started PoolLogic with nothing more than a truck and a pool
            pole. He had one goal: provide pool service the way he'd want it done on his own
            pool. That meant showing up when he said he would, doing thorough work every time,
            and treating every customer's pool like it was his own.
          </p>
          <p>
            Kyle built PoolLogic's reputation one pool at a time, right here in San Diego.
            Word spread fast; neighbors started recommending him to friends, and before long
            he was servicing pools across San Diego County. What started as a one-man operation
            grew into a full team of CPO-certified technicians who share Kyle's standards.
          </p>
          <p>
            Today, PoolLogic serves over {cities.length} cities across San Diego County.
            The team has grown, but Kyle's approach hasn't changed. He personally trains
            every technician and still holds the same commitment to reliability, transparency,
            and excellence that he had on day one.
          </p>
          <p>
            We're not the biggest pool company, and that's by design. We've chosen to stay
            local because we believe the best service comes from people who know the community
            they serve. When you call PoolLogic, you're not getting a call center;
            you're getting neighbors who care about doing right by you.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Values -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center">What We Stand For</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {values.map((value) => (
          <div class="bg-white rounded-xl p-6 shadow-sm text-center">
            <div class="w-14 h-14 bg-[#88d2c7]/20 rounded-full flex items-center justify-center text-[#00568c] mx-auto mb-4">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                {value.iconPaths ? (
                  value.iconPaths.map((p: string) => (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={p} />
                  ))
                ) : (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={value.iconPath} />
                )}
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{value.title}</h3>
            <p class="text-gray-600">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center">Our Journey</h2>
      <div class="max-w-3xl mx-auto">
        <div class="relative">
          <!-- Timeline line -->
          <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-[#88d2c7]/30"></div>

          {milestones.map((milestone) => (
            <div class="relative flex items-start mb-8 last:mb-0">
              <!-- Timeline dot -->
              <div class="absolute left-8 -translate-x-1/2 w-4 h-4 bg-[#00568c] rounded-full border-4 border-white shadow"></div>

              <!-- Content -->
              <div class="ml-16">
                <div class="text-lg font-bold text-[#00568c]">{milestone.year}</div>
                <div class="text-gray-600">{milestone.event}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">
            Why San Diego Homeowners Choose Us
          </h2>
          <div class="space-y-4">
            {whyChooseUs.map((item) => (
              <div class="flex gap-4">
                <div class="flex-shrink-0">
                  <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
                    <svg class="h-5 w-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  </div>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900">{item.title}</h3>
                  <p class="text-gray-600">{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Reviews highlight -->
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <div class="flex items-center gap-2 mb-6">
            <div class="flex">
              {[...Array(5)].map(() => (
                <svg class="h-6 w-6 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="font-semibold text-gray-900">{company.rating.value}/5</span>
            <span class="text-gray-500">({company.rating.count}+ reviews)</span>
          </div>

          <blockquote class="text-lg text-gray-700 mb-6">
            &ldquo;Pool Logic is by far the best pool servicing company we've used! Believe me, after 30 plus years owning a pool, we've had a number of scammers. PoolLogic is efficient, prompt, very knowledgeable and reasonably priced.&rdquo;
          </blockquote>

          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-gray-200 rounded-full flex items-center justify-center text-gray-500">
              <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <div class="font-semibold text-gray-900">Tracy Serrano</div>
              <div class="text-gray-500 text-sm">San Diego</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-4 text-center">Our Service Area</h2>
      <p class="text-lg text-gray-600 mb-8 text-center max-w-2xl mx-auto">
        Based in San Diego, we proudly serve homeowners and businesses throughout San Diego County.
      </p>
      <div class="bg-gray-50 rounded-xl p-6">
        <h3 class="font-semibold text-gray-900 mb-4">San Diego County</h3>
        <div class="flex flex-wrap gap-2">
          {cities.map((city) => (
            <a
              href={`/pool-service-${city.slug}/`}
              class="px-3 py-1 bg-white rounded-full text-sm text-gray-700 hover:bg-[#88d2c7]/20 hover:text-[#00568c] transition-colors"
            >
              {city.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 lg:py-24 bg-[#00568c] text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold mb-4">
        Ready to Experience the Difference?
      </h2>
      <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Join thousands of San Diego homeowners who trust PoolLogic Pool Service for their pool care.
        Get a free quote today.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={company.quoteUrl} external size="lg" variant="secondary">
          Get Your Free Quote
        </Button>
        <Button href={`tel:${company.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-[#00568c]">
          <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          Call {company.phone}
        </Button>
      </div>

      <p class="mt-6 text-blue-200 text-sm">
        CPO-certified technicians &bull; Cancel anytime &bull; Satisfaction guaranteed
      </p>
    </div>
  </section>
</BaseLayout>
