---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { company } from '@/data/company';
import { services } from '@/data/services';
import { metros } from '@/data/cities/index';
import Button from '@/components/ui/Button.astro';
import FAQ from '@/components/ui/FAQ.astro';
import { reviews } from '@/data/reviews';

const title = `${company.name} | California's Trusted Pool Service`;
const description = `Professional pool cleaning, maintenance, repairs and installations across California. ${company.poolsServed.toLocaleString()}+ satisfied customers. ${company.rating.value}/5 Google rating. Call ${company.phone}!`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={`${company.url}/`}
  ogTitle={`${company.name} | California's Trusted Pool Service`}
  ogDescription={`Professional pool service across California. Weekly cleaning, repairs, installations. ${company.rating.count}+ 5-star reviews.`}
  ogUrl={`${company.url}/`}
  twitterTitle={`${company.name} | California Pool Service`}
  twitterDescription={`California's trusted pool service. ${company.poolsServed.toLocaleString()}+ satisfied customers. Call ${company.phone}!`}
>
  <!-- Hero Section -->
  <section class="relative bg-brand-blue overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-blue via-brand-blue to-brand-blue-light opacity-90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-36">
      <div class="max-w-3xl">
        <h1 class="text-3xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          Your Time Isn't Free.
        </h1>
        <p class="text-lg sm:text-xl text-blue-100 mb-8 leading-relaxed max-w-2xl">
          Professional weekly pool service by certified experts. Get an instant quote in under 2 minutes.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href={company.quoteUrl} external size="lg" variant="secondary">
            Get Your Free Quote
          </Button>
          <Button href={`tel:${company.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-brand-blue">
            <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
            </svg>
            {company.phone}
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Stats Bar -->
  <section class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 sm:gap-8 text-center">
        <div>
          <p class="text-3xl sm:text-4xl font-bold text-brand-blue">1042+</p>
          <p class="text-gray-600 mt-1">Satisfied Customers</p>
        </div>
        <div>
          <p class="text-gray-600">Rated {company.rating.value}/5 by {company.rating.count.toLocaleString()}+ customer reviews</p>
        </div>
      </div>
      <p class="text-center text-gray-600 mt-4">From cleaning to repairs to installations, we've got you covered.</p>
    </div>
  </section>

  <!-- Services Overview Grid -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-brand-blue font-semibold mb-3">OUR SERVICES</p>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Set your pool on autopilot.
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          From cleaning to repairs to installations, we've got you covered.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <a
            href={`/${service.urlSlug}/`}
            class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md hover:border-brand-sky/30 transition-all group"
          >
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 bg-brand-blue/10 rounded-lg flex items-center justify-center">
                {service.category === 'maintenance' && (
                  <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                  </svg>
                )}
                {service.category === 'repair' && (
                  <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                )}
                {service.category === 'installation' && (
                  <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                  </svg>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-gray-900 group-hover:text-brand-blue transition-colors">
                  {service.name}
                </h3>
                <p class="text-sm text-gray-500 mt-1 line-clamp-2">{service.shortDescription}</p>
              </div>
              <svg class="w-5 h-5 text-gray-300 group-hover:text-brand-blue transition-colors flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- A Higher Standard of Pool Care -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          A Higher Standard of Pool Care.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-3">We Don't Just Say We Cleaned. We Prove It.</h3>
          <p class="text-gray-600">
            Get a photo of your sparkling pool and a chemical report emailed to you after every single visit. Never wonder if the pool guy showed up again.
          </p>
        </div>

        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Safe, Swim-Ready Water.</h3>
          <p class="text-gray-600">
            No red eyes. No itchy skin. Our CPO-certified pros precisely balance your water chemistry, so it's clear and healthy for your family.
          </p>
        </div>

        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Our "Never Green" Guarantee.</h3>
          <p class="text-gray-600">
            Our total guarantee means that if you're not completely satisfied, we'll come back and fix it, free of charge.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-brand-blue font-semibold mb-3">HOW IT WORKS</p>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Pool Care, Modernized.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center">
          <div class="w-16 h-16 bg-brand-blue rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Get your price instantly</h3>
          <p class="text-gray-600">
            Skip the phone tag and on-site visits. Just enter your address, and we'll generate a custom service plan for your pool in under two minutes.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-brand-blue rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Weekly care, with proof</h3>
          <p class="text-gray-600">
            Our vetted pros handle the chemistry, skimming, and scrubbing. The best part? You get a timestamped photo report emailed after every visit, so you know your pool is sparkling clean.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-brand-blue rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Enjoy your crystal-clear water</h3>
          <p class="text-gray-600">
            Swim in resort-quality water 24/7, and if you aren't 100% happy with a visit, we'll always make it right.
          </p>
        </div>
      </div>

      <div class="text-center mt-12">
        <Button href={company.quoteUrl} external size="lg" variant="secondary">
          See My Price
        </Button>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-brand-blue font-semibold mb-3">SERVICE AREAS</p>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Servicing pools all over California
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Professional pool service from San Diego to Sacramento. Find your area below.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {metros.map((metro) => {
          const hubCity = metro.cities.find(c => c.isPrimary);
          const href = hubCity?.urlPath || '#';
          return (
            <a
              href={href}
              class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md hover:border-brand-sky/30 transition-all text-center group"
            >
              <div class="w-12 h-12 bg-brand-blue/10 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 group-hover:text-brand-blue transition-colors mb-1">
                {metro.name}
              </h3>
              <p class="text-sm text-gray-500">{metro.cities.length} cities served</p>
            </a>
          );
        })}
      </div>

      <div class="text-center mt-10">
        <p class="text-gray-600 mb-4">
          Don&apos;t see your city? We likely serve your area.
        </p>
        <Button href={company.quoteUrl} external>
          Check Availability
        </Button>
      </div>
    </div>
  </section>

  <!-- Reviews Section -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-brand-blue font-semibold mb-3">CUSTOMER REVIEWS</p>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Your neighbors say it best.
        </h2>
        <div class="flex items-center justify-center gap-2 mb-2">
          <div class="flex">
            {[...Array(5)].map(() => (
              <svg class="h-6 w-6 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="font-semibold text-gray-900">{company.rating.value}/5</span>
          <span class="text-gray-500">({company.rating.count}+ reviews on Google)</span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {reviews.map((review) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="flex mb-3">
              {[...Array(review.rating)].map(() => (
                <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-gray-700 mb-4 leading-relaxed">&ldquo;{review.text}&rdquo;</p>
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 bg-brand-blue/10 rounded-full flex items-center justify-center">
                <span class="text-sm font-semibold text-brand-blue">{review.customerName.charAt(0)}</span>
              </div>
              <div>
                <p class="font-medium text-gray-900 text-sm">{review.customerName}</p>
                <p class="text-xs text-gray-500">{review.city}, CA</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ />

  <!-- Final CTA -->
  <section class="py-16 lg:py-24 bg-brand-blue">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-6">
        Ready for a Pool You Can Enjoy?
      </h2>
      <p class="text-lg sm:text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Join {company.poolsServed.toLocaleString()}+ satisfied customers across California.
        Get a free, no-obligation quote today.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-6">
        <Button href={company.quoteUrl} external size="lg" variant="secondary">
          Get Your Free Quote
        </Button>
        <Button href={`tel:${company.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-brand-blue">
          <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          Call {company.phone}
        </Button>
      </div>
      <p class="text-blue-200 text-sm">
        {company.serviceAreaDescription} &middot; {company.rating.count}+ 5-star reviews &middot; Licensed, bonded &amp; insured
      </p>
    </div>
  </section>
</BaseLayout>
