---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { company } from '@/data/company';
import { allCities, metros } from '@/data/cities';
import { services } from '@/data/services';

const title = `Sitemap | ${company.name}`;
const description = `Browse all pages on the ${company.name} website. Find pool services, service areas, resources, and more.`;

const maintenanceServices = services.filter(s => s.category === 'maintenance');
const repairServices = services.filter(s => s.category === 'repair');
const installationServices = services.filter(s => s.category === 'installation');
---

<BaseLayout
  title={title}
  description={description}
  canonical={`${company.url}/html-sitemap/`}
>
  <!-- Breadcrumbs -->
  <div class="py-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs
        items={[
          { name: 'Home', url: '/' },
          { name: 'Sitemap', url: '/html-sitemap/' },
        ]}
      />
    </div>
  </div>

  <!-- Content -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-8">Sitemap</h1>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        <!-- Main Pages -->
        <div>
          <h2 class="text-xl font-bold text-gray-900 mb-4">Main Pages</h2>
          <ul class="space-y-2">
            {[
              { name: 'Home', url: '/' },
              { name: 'Reviews', url: '/reviews/' },
              { name: 'Resources', url: '/resources/' },
              { name: 'Pool Service Near Me', url: '/pool-service-near-me/' },
              { name: 'Commercial Pool Service', url: '/commercial-pool-service/' },
              { name: 'Pool Service Pricing Guide', url: '/pool-service-pricing-guide/' },
              { name: 'Jobs & Careers', url: '/jobs-careers/' },
              { name: 'Sell Your Pool Service Company', url: '/sell-pool-service-company/' },
            ].map((page) => (
              <li>
                <a href={page.url} class="text-[#00568c] hover:underline">{page.name}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Services -->
        <div>
          <h2 class="text-xl font-bold text-gray-900 mb-4">Services</h2>

          {maintenanceServices.length > 0 && (
            <div class="mb-4">
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Maintenance</h3>
              <ul class="space-y-2">
                {maintenanceServices.map((service) => (
                  <li>
                    <a href={`/services/${service.urlSlug}/`} class="text-[#00568c] hover:underline">{service.name}</a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {repairServices.length > 0 && (
            <div class="mb-4">
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Repairs</h3>
              <ul class="space-y-2">
                {repairServices.map((service) => (
                  <li>
                    <a href={`/services/${service.urlSlug}/`} class="text-[#00568c] hover:underline">{service.name}</a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {installationServices.length > 0 && (
            <div class="mb-4">
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Installations</h3>
              <ul class="space-y-2">
                {installationServices.map((service) => (
                  <li>
                    <a href={`/services/${service.urlSlug}/`} class="text-[#00568c] hover:underline">{service.name}</a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <!-- Legal -->
        <div>
          <h2 class="text-xl font-bold text-gray-900 mb-4">Legal</h2>
          <ul class="space-y-2">
            {[
              { name: 'Privacy Policy', url: '/privacy-policy/' },
              { name: 'Terms of Use', url: '/terms-of-use/' },
            ].map((page) => (
              <li>
                <a href={page.url} class="text-[#00568c] hover:underline">{page.name}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Service Areas - Full Width -->
      <div class="mt-12">
        <h2 class="text-xl font-bold text-gray-900 mb-6">Service Areas</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {metros.map((metro) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-3">{metro.name}</h3>
              <ul class="space-y-1.5">
                {metro.cities.map((city) => (
                  <li>
                    <a
                      href={city.urlPath}
                      class={`hover:underline ${city.isPrimary ? 'text-[#00568c] font-medium' : 'text-[#00568c]'}`}
                    >
                      {city.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
