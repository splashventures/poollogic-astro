---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import Button from '@/components/ui/Button.astro';
import { company } from '@/data/company';

const title = `Commercial Pool Service | ${company.name}`;
const description = `Professional commercial pool service for HOAs, apartment complexes, gyms, and hotels across California. Licensed, bonded & insured. Call ${company.phone} for a commercial quote.`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={`${company.url}/commercial-pool-service/`}
  ogTitle={title}
  ogDescription="Professional commercial pool service for HOAs, apartment complexes, gyms, and hotels. Licensed, bonded & insured."
  ogUrl={`${company.url}/commercial-pool-service/`}
>
  <!-- Breadcrumbs -->
  <div class="py-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs
        items={[
          { name: 'Home', url: '/' },
          { name: 'Commercial Pool Service', url: '/commercial-pool-service/' },
        ]}
      />
    </div>
  </div>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-[#00568c] to-[#00568c]/80 text-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl lg:text-5xl font-bold mb-6">
          Commercial Pool Service
        </h1>
        <p class="text-xl text-blue-100 mb-8">
          {company.name} provides reliable, professional pool maintenance for HOAs, apartment complexes,
          gyms, hotels, and other commercial properties across California. We keep your facility safe,
          compliant, and swim-ready year round.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href={company.quoteUrl} external size="lg" variant="secondary">
            Get a Commercial Quote
          </Button>
          <Button href={`tel:${company.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-[#00568c]">
            <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
            </svg>
            {company.phone}
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Who We Serve -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Commercial Properties We Serve
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          From community pools to resort amenities, we have the expertise and capacity to maintain any commercial aquatic facility.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          {
            title: 'HOA & Community Pools',
            description: 'Keep your community pool clean, safe, and compliant with all health regulations. We handle scheduling, chemical management, and reporting for HOA boards.',
          },
          {
            title: 'Apartment Complexes',
            description: 'Reliable pool maintenance that keeps residents happy and management worry-free. Consistent service schedules with detailed documentation.',
          },
          {
            title: 'Hotels & Resorts',
            description: 'Crystal-clear pools that impress guests and meet hospitality standards. Flexible scheduling to minimize disruption during peak hours.',
          },
          {
            title: 'Gyms & Fitness Centers',
            description: 'High-traffic pools and spas require specialized attention. We manage heavy bather loads and maintain optimal water chemistry throughout the day.',
          },
          {
            title: 'Country Clubs & Recreation Centers',
            description: 'Premium maintenance for premium facilities. We understand the elevated standards that members expect from their aquatic amenities.',
          },
          {
            title: 'Municipal & Public Pools',
            description: 'Health department compliant service with detailed record-keeping, chemical logs, and proactive maintenance to keep public pools operating safely.',
          },
        ].map((item) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">{item.title}</h3>
            <p class="text-gray-600">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Commercial Services -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Our Commercial Services
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {[
          'Weekly chemical testing and water balancing',
          'Surface skimming and debris removal',
          'Tile and deck cleaning',
          'Filter maintenance and cleaning',
          'Equipment inspection and repair',
          'Health department compliance support',
          'Emergency service and on-call support',
          'Detailed service logs and reporting',
          'Seasonal opening and closing',
          'Renovation and resurfacing coordination',
        ].map((service) => (
          <div class="flex items-start gap-3">
            <svg class="h-6 w-6 text-[#00568c] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-gray-700 text-lg">{service}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Cabana for Commercial -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Why Choose {company.name}?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { title: 'Licensed & Insured', description: `CA Contractors License #${company.contractorsLicense}. Fully bonded and insured for your protection.` },
          { title: 'Dedicated Account Manager', description: 'A single point of contact who understands your property and handles all scheduling and communication.' },
          { title: 'Digital Service Reports', description: 'Detailed reports after every visit with photos, chemical readings, and equipment status updates.' },
          { title: 'Flexible Scheduling', description: 'Service schedules designed around your property needs, including weekends and early mornings.' },
        ].map((item) => (
          <div class="text-center">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 lg:py-24 bg-[#00568c]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
        Get a Commercial Pool Service Quote
      </h2>
      <p class="text-xl text-blue-100 mb-8">
        Tell us about your property and we will provide a customized maintenance plan and quote.
        No obligation, no pressure.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={company.quoteUrl} external size="lg" variant="secondary">
          Request a Commercial Quote
        </Button>
        <Button href={`tel:${company.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-[#00568c]">
          <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          Call {company.phone}
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
