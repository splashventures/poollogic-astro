---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import Button from '@/components/ui/Button.astro';
import { company } from '@/data/company';

const title = `Commercial Pool Service | ${company.name}`;
const description = `Professional commercial pool service for HOAs, apartment complexes, gyms, and hotels across California. Licensed, bonded & insured. Call ${company.phone} for a commercial quote.`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={`${company.url}/commercial-pool-service/`}
  ogTitle={title}
  ogDescription="Professional commercial pool service for HOAs, apartment complexes, gyms, and hotels. Licensed, bonded & insured."
  ogUrl={`${company.url}/commercial-pool-service/`}
>
  <!-- Breadcrumbs -->
  <div class="py-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs
        items={[
          { name: 'Home', url: '/' },
          { name: 'Commercial Pool Service', url: '/commercial-pool-service/' },
        ]}
      />
    </div>
  </div>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-[#00568c] to-[#00568c]/80 text-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl lg:text-5xl font-bold mb-6">
          Commercial Pool Service. Compliant. Insured. Reliable.
        </h1>
        <p class="text-xl text-blue-100 mb-8">
          Protect your property and your residents. We provide CPO-certified maintenance, health department logs, and $2M liability coverage. Keep your pool open and your residents happy.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href={company.quoteUrl} external size="lg" variant="secondary">
            Request a Proposal
          </Button>
          <Button href={`tel:${company.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-[#00568c]">
            <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
            </svg>
            {company.phone}
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Mitigate Your Risk -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Mitigate Your Risk. Maximize Tenant Satisfaction.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          {
            title: 'Audit-Ready Logs',
            description: 'We maintain digital chemical records compliant with local health department codes.',
          },
          {
            title: 'Proactive Repairs',
            description: 'We spot equipment failure before the pool turns green, preventing costly downtime.',
          },
          {
            title: 'Liability Protection',
            description: 'Fully licensed, bonded, and insured. We take the liability off your plate.',
          },
        ].map((item) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">{item.title}</h3>
            <p class="text-gray-600">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- A Higher Standard of Pool Care -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          A Higher Standard of Pool Care.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-3">A Community Amenity, Not a Liability.</h3>
          <p class="text-gray-600">
            Whether it's attracting new tenants or keeping homeowners happy, a closed pool is a headache. We prioritize "uptime", responding rapidly to issues to ensure your amenity remains open, safe, and sparkling.
          </p>
        </div>
        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Total Visibility for Property Managers.</h3>
          <p class="text-gray-600">
            We provide service logs, photo proof of every visit, and proactive equipment alerts. You'll have the answers before the residents even ask the questions.
          </p>
        </div>
        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Predictable Costs, No Surprises.</h3>
          <p class="text-gray-600">
            We understand strict budgets and reserve planning. Our commercial plans are designed for fiscal stability, focusing on preventative maintenance to extend equipment life and avoid the "sticker shock" of unexpected repairs.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included with Weekly Service -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          What's included with our weekly pool cleaning service?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {[
          { title: 'Check & Balance Pool Chemicals', description: 'Say farewell to hassle as we balance your pool chemicals for optimum water quality.' },
          { title: 'Inspect Filter System & Backwash', description: 'Clean filters are the secret to an immaculate pool all year long.' },
          { title: 'Manually Vacuum Pool Surfaces', description: 'Nothing can replace a thorough, hand cleaning.' },
          { title: 'Treat for Algae', description: 'Conquer the green with our expert algae treatments.' },
          { title: 'Clean Skimmer & Pump Baskets', description: 'We keep the water flowing freely to help ensure your pool is immaculate.' },
          { title: 'Empty Catch & Maintain Automatic Pool Vacuum', description: "It's all about peace of mind that everything's operating optimally." },
          { title: 'Brush Steps & Walls', description: 'Regular deep cleaning ensures you have a tranquil oasis.' },
          { title: 'Skim Water, Clean Leaves, Remove Debris', description: 'We leave your pool looking immaculate for worry-free enjoyment.' },
          { title: 'Detailed Post-Service Report', description: 'We detail every step and all our findings so you can make accurate decisions.' },
        ].map((item) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Expertly Handling Commercial Needs -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Expertly Handling Your Commercial Pool Service Needs
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {[
          { title: 'Health Code Compliance', description: 'Precise chemical balancing to meet local health department standards, minimizing the risk of closures or liability issues.' },
          { title: 'Asset Preservation', description: "We don't just clean; we inspect. Proactive checks on pumps, filters, and heaters to catch small issues before they become expensive CapEx repairs." },
          { title: 'Aesthetic Excellence', description: 'We understand the pool is your top leasing amenity. We ensure the water, tile, and surface are tour-ready every single day.' },
          { title: 'Algae Prevention Guarantee', description: 'We stop problems before they start. Our preventative chemical protocols ensure your community never wakes up to a green pool.' },
          { title: 'Audit-ready reporting', description: 'Receive a detailed service report after every visit. Includes photos and chemical readings, perfect for HOA board meetings or owner reports.' },
          { title: 'Priority Dispatch', description: 'Commercial clients get VIP status. If equipment fails, we prioritize your repair to minimize downtime and keep residents happy.' },
        ].map((item) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Seamless Transition -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          A Seamless Transition to a Better Commercial Pool Service
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center">
          <div class="w-16 h-16 bg-[#00568c] rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Complimentary Site Audit</h3>
          <p class="text-gray-600">
            We don't guess. We visit your property to inspect equipment, assess safety compliance, and understand your specific needs before quoting.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-[#00568c] rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">The Flat-Rate Proposal</h3>
          <p class="text-gray-600">
            Receive a transparent monthly plan designed for budget stability. No hidden fees or surprise surcharges, just predictable costs.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-[#00568c] rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Autonomous Operation</h3>
          <p class="text-gray-600">
            We handle the takeover and operations completely. You receive digital reports after every visit, keeping you informed without the micromanagement.
          </p>
        </div>
      </div>

      <div class="text-center mt-12">
        <Button href={company.quoteUrl} external size="lg" variant="secondary">
          Request a Proposal
        </Button>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 lg:py-24 bg-[#00568c]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
        Make the Pool the Easiest Part of Your Property.
      </h2>
      <p class="text-xl text-blue-100 mb-8">
        Stop micromanaging your pool vendor. Join the Multi-Family properties and HOAs that trust Cabana for compliant, headache-free asset management. Get a higher standard of service without the stress.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={company.quoteUrl} external size="lg" variant="secondary">
          Request a Proposal
        </Button>
        <Button href={`tel:${company.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-[#00568c]">
          <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          Call {company.phone}
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
