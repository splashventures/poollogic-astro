---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import Button from '@/components/ui/Button.astro';
import { company } from '@/data/company';

const title = `Sell Your Pool Service Company | ${company.name}`;
const description = `Looking to sell your pool service company? ${company.name} acquires pool service businesses across California. Fair valuations, smooth transitions, and your team is taken care of.`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={`${company.url}/sell-pool-service-company/`}
  ogTitle={title}
  ogDescription="Sell your pool service company to Cabana. Fair valuations, smooth transitions, and your team is taken care of."
  ogUrl={`${company.url}/sell-pool-service-company/`}
>
  <!-- Breadcrumbs -->
  <div class="py-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs
        items={[
          { name: 'Home', url: '/' },
          { name: 'Sell Your Pool Service Company', url: '/sell-pool-service-company/' },
        ]}
      />
    </div>
  </div>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-[#00568c] to-[#00568c]/80 text-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl lg:text-5xl font-bold mb-6">
          We're Cabana.<br />We buy wonderful pool service companies.
        </h1>
        <p class="text-xl text-blue-100 mb-8">
          We buy exceptional pool service companies and invest in their teams, creating the next generation of pool industry leaders.
        </p>
        <Button href={`mailto:${company.email}?subject=Interested in selling my pool service company`} size="lg" variant="secondary">
          Get In Touch
        </Button>
      </div>
    </div>
  </section>

  <!-- Why Partner with Cabana -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Why partner with Cabana?
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          From day one, we've proudly partnered with exceptional pool service companies while achieving what matters most: 94% of customers stay with us, and 97% of employees continue building their careers here. Our team of pool industry veterans doesn't just understand the business; we're passionate about it. We know the dedication it takes to build a successful pool service company, and we honor that legacy. Ready to explore what's next for your business? Let's talk.
        </p>
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Our process
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 max-w-5xl mx-auto">
        {[
          { step: '1', title: 'Initial conversation', description: 'A friendly, no-pressure chat about your business. No paperwork needed; just tell us your story and goals.' },
          { step: '2', title: 'Fair value offer', description: "Within 48 hours, you'll receive an offer that reflects the true value of the business you've worked hard to build." },
          { step: '3', title: 'Simple agreement', description: 'One clear contract that protects your interests, written in plain English, not legal jargon. Simple, transparent terms that your lawyer will appreciate.' },
          { step: '4', title: 'Quick closing', description: 'Funds in your account in as little as 30 days. We handle all the paperwork while you focus on your business.' },
        ].map((item) => (
          <div class="text-center">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-[#00568c] text-white text-xl font-bold mb-4">
              {item.step}
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Get the Exit You Deserve -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Get the exit you deserve
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            title: 'Secure your legacy',
            description: "You've worked hard for years and built a valuable business. We will honor your company's reputation while taking exceptional care of your loyal customers and dedicated employees.",
          },
          {
            title: 'Get a fair value',
            description: 'As pool industry specialists, we recognize the true worth of your business and offer competitive deals with flexible terms. Our streamlined process means you can receive funds in your bank account in as little as 30 days.',
          },
          {
            title: 'Enjoy a smooth transition',
            description: 'Forget complex negotiations and endless paperwork. Our streamlined process is built for busy pool professionals: One meeting to discuss terms, one fair offer, one simple contract.',
          },
        ].map((item) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">{item.title}</h3>
            <p class="text-gray-600">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What Sellers Have to Say -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          What sellers have to say
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="bg-white border border-gray-200 rounded-xl p-6">
          <p class="text-gray-700 mb-4 leading-relaxed">&ldquo;Working with Cabana has been amazing! They really know their craft and make the process of selling smooth and easy. Best of all, they actually know pools. I have been approached by so many other groups wanting to buy my company, but Cabana was the only team who knew what it takes to successfully run a pool service company. They should be every owner's first call when you are ready to sell.&rdquo;</p>
          <div>
            <p class="font-semibold text-gray-900">Kyle Bowman</p>
            <p class="text-sm text-gray-500">Founder of PoolLogic, San Diego, CA</p>
          </div>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-6">
          <p class="text-gray-700 mb-4 leading-relaxed">&ldquo;We considered selling a number of times, but never quite got comfortable with the buyers until we met Cabana. These guys know the pool industry, and are the first group we talked to who we knew would take care of our customers, our team, and the business we've built over the last 40 years.&rdquo;</p>
          <div>
            <p class="font-semibold text-gray-900">Bill A.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's In It for Your Team -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          What's in it for your team?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {[
          {
            title: 'Career growth opportunities',
            description: 'Great people build great companies. We understand the importance of retaining key talent, supporting them with continuing education, attractive benefits, and defined growth paths. As part of Cabana, a national organization, your team members gain access to coast-to-coast mobility and clear career paths from field operations to executive leadership.',
          },
          {
            title: 'Professional development',
            description: "We'll help them earn their Certified Pool Operator credentials, with ongoing opportunities for additional professional certifications. We are committed to the craft of pool care, and helping your team continue to master this field.",
          },
          {
            title: 'Performance-based rewards',
            description: 'Success is meant to be shared! We believe in recognizing and rewarding our team members through both referral and performance-based bonus programs.',
          },
          {
            title: 'Leading industry innovation',
            description: "Your team will be part of modernizing the pool care industry. At Cabana, we're bringing cutting-edge technology and new processes to an established industry, creating the future of pool service together.",
          },
        ].map((item) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">{item.title}</h3>
            <p class="text-gray-600">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Questions on selling your pool business?
        </h2>
      </div>

      <div class="bg-white rounded-2xl border border-gray-200 px-4 sm:px-8">
        {[
          {
            question: 'How much is my pool service company worth?',
            answer: "We value companies based on a combination of monthly service revenue, cash flow, growth rate, and size of the company. Every business is unique, and we will work to come up with a valuation that is tailored to your business. If you'd like to learn what your pool company is worth, please reach out. We can get you a quick, no-commitment valuation within 48 hours.",
          },
          {
            question: 'Can I stay involved after the sale?',
            answer: 'Absolutely! We offer flexible transition arrangements, from complete exits to ongoing consulting roles. You decide what works best for you.',
          },
          {
            question: 'What happens to my employees?',
            answer: 'We retain 97% of all employees from acquired companies, often with enhanced benefits and growth opportunities.',
          },
          {
            question: 'How long does the process take?',
            answer: 'While traditional sales can take 6-12 months, our streamlined process can close in as little as 30 days from offer acceptance.',
          },
        ].map((faq, index) => (
          <div class={`py-6 ${index < 3 ? 'border-b border-gray-200' : ''}`}>
            <h3 class="font-semibold text-lg text-gray-900 mb-2">{faq.question}</h3>
            <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 lg:py-24 bg-[#00568c]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
        Let's talk
      </h2>
      <p class="text-xl text-blue-100 mb-8">
        If you're interested in exploring a sale of your pool company, we'd love to talk.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={`mailto:${company.email}?subject=Interested in selling my pool service company`} size="lg" variant="secondary">
          Get In Touch
        </Button>
        <Button href={`tel:${company.phoneRaw}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-[#00568c]">
          <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          Call {company.phone}
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
